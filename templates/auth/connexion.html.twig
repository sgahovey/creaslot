{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{# Pages d'auth : masquer header, footer et flash (ils sont dans la carte) #}
{% block header %}{% endblock %}
{% block footer %}{% endblock %}
{% block flash_messages %}{% endblock %}

{% block body %}
<div class="cs-auth-wrapper">
    <div class="cs-auth-card">

        {# En-tête de la carte #}
        <div class="d-flex align-items-center gap-2 mb-4">
            <i class="bi bi-calendar-check-fill" style="font-size: 1.5rem; color: var(--cs-blue-primary);" aria-hidden="true"></i>
            <span class="cs-auth-logo">CreaSlot</span>
        </div>

        <h1 class="cs-auth-title">Connexion</h1>
        <p class="cs-auth-subtitle">Accédez à votre espace de gestion des rendez-vous.</p>

        {# Messages flash #}
        {% for message in app.flashes('success') %}
            <div class="alert alert-success d-flex align-items-center gap-2 mb-3" role="alert">
                <i class="bi bi-check-circle-fill" aria-hidden="true"></i>
                <span>{{ message }}</span>
            </div>
        {% endfor %}
        {% for message in app.flashes('info') %}
            <div class="alert alert-info d-flex align-items-center gap-2 mb-3" role="alert">
                <i class="bi bi-info-circle-fill" aria-hidden="true"></i>
                <span>{{ message }}</span>
            </div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger d-flex align-items-center gap-2 mb-3" role="alert">
                <i class="bi bi-exclamation-triangle-fill" aria-hidden="true"></i>
                <span>{{ message }}</span>
            </div>
        {% endfor %}

        {# Erreur d'authentification — message générique (OWASP : ne jamais révéler si c'est l'email ou le mot de passe) #}
        {% if erreur %}
            <div class="alert alert-danger d-flex align-items-center gap-2 mb-3" role="alert">
                <i class="bi bi-exclamation-triangle-fill" aria-hidden="true"></i>
                <span>Identifiants incorrects.</span>
            </div>
        {% endif %}

        {# Formulaire de connexion — soumis vers check_path (même route, POST) #}
        <form method="post" action="{{ path('app_login') }}" novalidate>

            {# Token CSRF anti-falsification de requête #}
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            {# Email #}
            <div class="mb-3">
                <label for="email" class="form-label">
                    Adresse email
                </label>
                <input
                    type="email"
                    id="email"
                    name="email"
                    class="form-control"
                    value="{{ dernierEmail }}"
                    placeholder="votre.email@exemple.fr"
                    autocomplete="email"
                    required
                    autofocus
                >
            </div>

            {# Mot de passe — pas de contraintes de complexité ici, on vérifie un hash existant #}
            <div class="mb-4">
                <label for="password" class="form-label">
                    Mot de passe
                </label>
                <input
                    type="password"
                    id="password"
                    name="password"
                    class="form-control"
                    placeholder="Votre mot de passe"
                    autocomplete="current-password"
                    required
                >
                <div class="text-end mt-2">
                    <a href="{{ path('app_mot_de_passe_oublie') }}" style="font-size: var(--cs-fs-small);">Mot de passe oublié ?</a>
                </div>
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="bi bi-box-arrow-in-right" aria-hidden="true"></i>
                    Se connecter
                </button>
            </div>

        </form>

        <div class="cs-auth-footer">
            Pas encore de compte ?
            <a href="{{ path('app_inscription') }}">S'inscrire</a>
        </div>

    </div>
</div>
{% endblock %}
