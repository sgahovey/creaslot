{#
 # Tableau de bord Super-admin — KPIs chiffrés (US-5.1) + graphique d'occupation (US-5.2).
 #
 # Données strictement agrégées (compteurs + ratio) : aucune information nominative.
 # Variables attendues :
 #   kpis        App\DTO\TableauBordKpis
 #   occupation  list<App\DTO\OccupationJournaliere> (série 30 jours)
 #}
{% extends 'admin/base_admin.html.twig' %}

{% block title %}Tableau de bord{% endblock %}

{% block admin_contenu %}
    <div class="row g-3 g-md-4">

        {# ── Carte A : Réservations à venir ──────────────────────────────── #}
        <div class="col-12 col-md-6">
            <article class="card border-0 shadow-sm h-100" style="border-radius: var(--cs-radius-lg);">
                <div class="card-body p-4">
                    <h2 class="text-uppercase mb-3 d-flex align-items-center gap-2"
                        style="color: var(--cs-text-secondary); font-size: var(--cs-fs-small); letter-spacing: .03em;">
                        <i class="bi bi-calendar-check" aria-hidden="true"></i>
                        Réservations à venir
                    </h2>
                    <p class="display-4 mb-1"
                       style="color: var(--cs-blue-primary); font-weight: var(--cs-fw-bold);">
                        {{ kpis.reservationsActives }}
                    </p>
                    <p class="mb-0" style="color: var(--cs-text-secondary); font-size: var(--cs-fs-small);">
                        rendez-vous actifs encore à honorer
                    </p>
                </div>
            </article>
        </div>

        {# ── Carte B : Taux d'occupation ─────────────────────────────────── #}
        <div class="col-12 col-md-6">
            <article class="card border-0 shadow-sm h-100" style="border-radius: var(--cs-radius-lg);">
                <div class="card-body p-4">
                    <h2 class="text-uppercase mb-3 d-flex align-items-center gap-2"
                        style="color: var(--cs-text-secondary); font-size: var(--cs-fs-small); letter-spacing: .03em;">
                        <i class="bi bi-pie-chart" aria-hidden="true"></i>
                        Taux d'occupation
                    </h2>
                    <p class="display-4 mb-1"
                       style="color: var(--cs-success); font-weight: var(--cs-fw-bold);">
                        {{ kpis.tauxOccupation }} %
                    </p>
                    <p class="mb-1" style="color: var(--cs-text-secondary); font-size: var(--cs-fs-small);">
                        {{ kpis.creneauxReserves }} / {{ kpis.creneauxOffre }} créneaux réservés
                    </p>
                    <p class="mb-0" style="color: var(--cs-text-secondary); font-size: var(--cs-fs-tiny);">
                        du {{ kpis.fenetreDebut|date('d/m/Y', 'Indian/Reunion') }}
                        au {{ kpis.fenetreFin|date('d/m/Y', 'Indian/Reunion') }}
                    </p>
                </div>
            </article>
        </div>

    </div>

    {# ── Graphique d'occupation 30 jours (US-5.2) ─────────────────────────── #}
    <section class="mt-4 mt-md-5"
             aria-labelledby="cs-graph-occupation-titre"
             data-controller="graphique-occupation"
             data-graphique-occupation-series-value="{{ occupation|map(o => { jour: o.jour, offre: o.offre, reserves: o.reserves })|json_encode|e('html_attr') }}">

        <h2 id="cs-graph-occupation-titre" class="h5 d-flex align-items-center gap-2 mb-3"
            style="color: var(--cs-text-primary); font-weight: var(--cs-fw-semibold);">
            <i class="bi bi-bar-chart-line" aria-hidden="true"></i>
            Occupation des 30 derniers jours
        </h2>

        <div class="card border-0 shadow-sm" style="border-radius: var(--cs-radius-lg);">
            <div class="card-body p-3 p-md-4">

                <div style="position: relative; height: 320px;">
                    <canvas data-graphique-occupation-target="canvas"
                            role="img"
                            aria-label="Graphique en barres des créneaux offerts et réservés par jour sur les 30 derniers jours. Le détail chiffré est disponible dans le tableau « Voir les données du graphique » ci-dessous."></canvas>
                </div>

                <details class="mt-3">
                    <summary>Voir les données du graphique</summary>
                    <div class="table-responsive mt-2">
                        <table class="table table-sm align-middle">
                            <caption class="visually-hidden">Créneaux offerts et réservés par jour sur les 30 derniers jours</caption>
                            <thead>
                                <tr>
                                    <th scope="col">Jour</th>
                                    <th scope="col" class="text-end">Offerts</th>
                                    <th scope="col" class="text-end">Réservés</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for o in occupation %}
                                    <tr>
                                        <th scope="row" class="fw-normal">{{ o.jour|date('d/m/Y', 'Indian/Reunion') }}</th>
                                        <td class="text-end">{{ o.offre }}</td>
                                        <td class="text-end">{{ o.reserves }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </details>

            </div>
        </div>
    </section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {# Chart.js v4 — bundle UMD vendorisé, chargé UNIQUEMENT sur le dashboard (expose window.Chart) #}
    <script src="{{ asset('vendor/chartjs/chart.umd.min.js') }}"></script>
{% endblock %}
