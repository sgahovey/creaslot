{#
 # Gestion des comptes — création (US-5.3, morceau 3).
 #
 # Le thème bootstrap_5 est appliqué localement (labels associés, RGAA) sans
 # config globale. Variable : formulaire (UtilisateurAdminType, avec_mot_de_passe).
 #}
{% extends 'admin/base_admin.html.twig' %}

{% form_theme formulaire 'bootstrap_5_layout.html.twig' %}

{% block title %}Nouveau compte{% endblock %}

{% block admin_contenu %}

    <div class="mb-3">
        <a href="{{ path('app_admin_comptes') }}" class="btn btn-sm btn-link text-decoration-none px-0">
            <i class="bi bi-arrow-left" aria-hidden="true"></i>
            Retour à la liste
        </a>
    </div>

    <h2 class="h5 d-flex align-items-center gap-2 mb-3"
        style="color: var(--cs-text-primary); font-weight: var(--cs-fw-semibold);">
        <i class="bi bi-person-plus" aria-hidden="true"></i>
        Nouveau compte
    </h2>

    <div class="card border-0 shadow-sm" style="border-radius: var(--cs-radius-lg);">
        <div class="card-body p-4" style="max-width: 640px;">

            {{ form_start(formulaire) }}

                <div class="row g-3">
                    <div class="col-12 col-sm-6">{{ form_row(formulaire.prenom) }}</div>
                    <div class="col-12 col-sm-6">{{ form_row(formulaire.nom) }}</div>
                </div>

                {{ form_row(formulaire.email) }}
                {{ form_row(formulaire.role) }}
                {{ form_row(formulaire.service) }}
                {{ form_row(formulaire.motDePasse.first) }}
                {{ form_row(formulaire.motDePasse.second) }}

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg" aria-hidden="true"></i>
                        Créer le compte
                    </button>
                    <a href="{{ path('app_admin_comptes') }}" class="btn btn-outline-secondary">Annuler</a>
                </div>

            {{ form_end(formulaire) }}

        </div>
    </div>

{% endblock %}
