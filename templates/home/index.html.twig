{% extends 'base.html.twig' %}

{% block title %}Environnement Docker{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-7">

            <div class="card shadow-sm border" style="border-color: var(--cs-border) !important; border-radius: var(--cs-radius-lg);">
                <div class="card-body p-4">

                    {# Logo CreaSlot #}
                    <h1 class="fw-bold mb-1" style="color: var(--cs-blue-primary); font-size: 1.75rem;">
                        CreaSlot
                    </h1>
                    <p class="mb-4" style="color: var(--cs-text-secondary); font-size: 0.9rem;">
                        Application de gestion de rendez-vous — Cnam Réunion
                    </p>

                    {# Confirmation Symfony opérationnel #}
                    <div class="alert d-flex align-items-center gap-2 mb-4 py-3"
                         style="background: #D4EDDA; color: #155724; border: 1px solid #C3E6CB; border-radius: var(--cs-radius-md);"
                         role="status">
                        <i class="bi bi-check-circle-fill" aria-hidden="true"></i>
                        <strong>Symfony {{ symfony_version }} opérationnel</strong>
                    </div>

                    {# Informations système #}
                    <p class="text-uppercase fw-bold mb-2"
                       style="font-size: 0.75rem; letter-spacing: 0.08em; color: var(--cs-text-secondary); border-bottom: 1px solid var(--cs-border); padding-bottom: 6px;">
                        Informations système
                    </p>
                    <div class="row g-3 mb-4">
                        <div class="col-6">
                            <div style="font-size: 0.875rem;">
                                <div style="color: var(--cs-text-secondary);">Version PHP</div>
                                <div class="fw-semibold font-monospace">{{ php_version }}</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div style="font-size: 0.875rem;">
                                <div style="color: var(--cs-text-secondary);">Version Symfony</div>
                                <div class="fw-semibold font-monospace">{{ symfony_version }}</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div style="font-size: 0.875rem;">
                                <div style="color: var(--cs-text-secondary);">Environnement (APP_ENV)</div>
                                <div class="fw-semibold font-monospace">{{ app.environment }}</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div style="font-size: 0.875rem;">
                                <div style="color: var(--cs-text-secondary);">Mode debug</div>
                                <div class="fw-semibold font-monospace">{{ app.debug ? 'activé' : 'désactivé' }}</div>
                            </div>
                        </div>
                    </div>

                    {# Statut des extensions PHP #}
                    <p class="text-uppercase fw-bold mb-2"
                       style="font-size: 0.75rem; letter-spacing: 0.08em; color: var(--cs-text-secondary); border-bottom: 1px solid var(--cs-border); padding-bottom: 6px;">
                        Extensions PHP requises par Symfony
                    </p>
                    <div class="d-flex flex-wrap gap-2 mb-4">
                        {% for nom, chargee in extensions_status %}
                            <span class="badge rounded-pill font-monospace"
                                  style="background: {{ chargee ? '#D4EDDA' : '#F8D7DA' }}; color: {{ chargee ? '#155724' : '#721C24' }}; font-size: 0.8rem; padding: 5px 12px;">
                                <i class="bi {{ chargee ? 'bi-check-circle-fill' : 'bi-x-circle-fill' }}" aria-hidden="true"></i>
                                {{ nom }}
                            </span>
                        {% endfor %}
                    </div>

                    {# Prochaine étape #}
                    <div class="p-3 rounded" style="background: var(--cs-bg-subtle); font-size: 0.875rem; color: #495057;">
                        <strong style="color: var(--cs-text-primary);">Prochaine étape :</strong>
                        US-1.3 — Mise en place de l'authentification (inscription, connexion, rôles).
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}
