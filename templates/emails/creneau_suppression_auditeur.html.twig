{#
 # Template email — Notification de suppression d'un créneau (US-4.5).
 #
 # Envoyé à l'Auditeur quand le Personnel supprime un créneau que
 # l'auditeur avait réservé (soft delete via setEstActif(false) +
 # annulerReservationLiee() côté CreneauController::supprimer). Émis
 # UNIQUEMENT si la Reservation associée existe avec statut ANNULEE
 # (garde-fou strict du service, cf. notifierAuditeurSuppressionCreneau).
 #
 # ── Asymétrie RGPD volontaire ─────────────────────────────────────────────
 # Le motif d'annulation interne ('Créneau supprimé par le Personnel')
 # N'EST PAS exposé dans l'email — minimisation : c'est une donnée
 # technique interne sans valeur ajoutée pour l'auditeur, qui apprend
 # la suppression via le sujet et l'intro de cet email.
 # Cohérent avec la politique des templates US-4.3 (motif d'annulation
 # JAMAIS exposé côté Personnel) et US-4.4 (logs en longueur uniquement).
 #
 # Le sujet de l'email est construit en PHP par
 # NotificationService::notifierAuditeurSuppressionCreneau(), pas via un
 # {% block subject %} dans ce template. Raison : le sujet intègre la date
 # formatée du créneau (timezone Indian/Reunion) et doit être préfixable
 # en mode redirection DEV ("[DEV→destinataire] Votre créneau a été supprimé
 # par le Personnel — …"). Ce template est responsable du body uniquement.
 #
 # Variables :
 #   auditeur_prenom            string                — pour la salutation
 #   personnel_nom_complet      string                — "Prénom Nom" (auteur de la suppression)
 #   service_nom                ?string               — null si Personnel non rattaché (Super-admin)
 #   creneau_debut              \DateTimeInterface    — début du créneau supprimé
 #   creneau_fin                \DateTimeInterface    — fin du créneau supprimé
 #   lien_creneaux_disponibles  string                — URL absolue vers app_creneaux_disponibles
 #}

{% extends 'emails/_layout.html.twig' %}

{% block titre %}Votre créneau a été supprimé — CreaSlot{% endblock %}

{% block sous_titre %}Votre créneau a été supprimé{% endblock %}

{% block contenu %}

                            <p style="margin: 0 0 16px 0; color: #333333; font-size: 15px; font-family: Arial, sans-serif;">
                                Bonjour {{ auditeur_prenom }},
                            </p>

                            <p style="margin: 0 0 24px 0; color: #333333; font-size: 14px; line-height: 1.5; font-family: Arial, sans-serif;">
                                {{ personnel_nom_complet }} a supprimé le créneau que vous aviez réservé. Votre réservation a été annulée en conséquence.
                            </p>

                            {# ── Encadré récap (bordure gauche bleu marine) ── #}
                            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"
                                   style="margin: 0 0 24px 0;">
                                <tr>
                                    <td style="background-color: #f8f9fa; border-left: 4px solid #1A3E6F; padding: 16px 20px; color: #333333; font-size: 14px; line-height: 1.6; font-family: Arial, sans-serif;">

                                        <p style="margin: 0 0 8px 0;">
                                            <strong style="color: #1A3E6F;">Date&nbsp;:</strong>
                                            {{ creneau_debut|format_date(locale='fr_FR', pattern='EEEE d MMMM y', timezone='Indian/Reunion')|capitalize }}
                                        </p>

                                        <p style="margin: 0 0 8px 0;">
                                            <strong style="color: #1A3E6F;">Horaire&nbsp;:</strong>
                                            {{ creneau_debut|date('H\\hi', 'Indian/Reunion') }} – {{ creneau_fin|date('H\\hi', 'Indian/Reunion') }}
                                        </p>

                                        <p style="margin: 0 0 8px 0;">
                                            <strong style="color: #1A3E6F;">Avec&nbsp;:</strong>
                                            {{ personnel_nom_complet }}
                                        </p>

                                        {% if service_nom %}
                                        <p style="margin: 0 0 8px 0;">
                                            <strong style="color: #1A3E6F;">Service&nbsp;:</strong>
                                            {{ service_nom }}
                                        </p>
                                        {% endif %}

                                    </td>
                                </tr>
                            </table>

                            {# ── CTA "Voir d'autres créneaux disponibles" ─── #}
                            <table role="presentation" cellpadding="0" cellspacing="0" border="0"
                                   style="margin: 8px auto 16px auto;">
                                <tr>
                                    <td align="center" style="background-color: #1A3E6F; border-radius: 4px;">
                                        <a href="{{ lien_creneaux_disponibles }}"
                                           style="display: inline-block; padding: 12px 28px; color: #ffffff; font-size: 14px; font-weight: bold; font-family: Arial, sans-serif; text-decoration: none;">
                                            Voir d'autres créneaux disponibles
                                        </a>
                                    </td>
                                </tr>
                            </table>

                            <p style="margin: 0; color: #555555; font-size: 13px; line-height: 1.5; font-family: Arial, sans-serif;">
                                N'hésitez pas à réserver un autre créneau qui vous conviendrait.
                            </p>

{% endblock %}
