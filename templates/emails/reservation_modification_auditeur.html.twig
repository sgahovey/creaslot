{#
 # Template email — Notification de mise à jour du commentaire d'un rendez-vous (US-4.4).
 #
 # Envoyé à l'Auditeur quand le Personnel modifie le commentaire (message
 # Personnel→Auditeur) d'un créneau que l'auditeur a réservé. Émis UNIQUEMENT
 # si le commentaire change (ajout, modification ou retrait). Les horaires
 # et le typeRdv ne sont pas modifiables sur un créneau réservé via le
 # formulaire (cf. CreneauType + CreneauController).
 #
 # ── Affichage du commentaire — UX choisie ─────────────────────────────────
 # Pas de bloc "Avant/Après" du commentaire : on affiche UNIQUEMENT le
 # nouveau (charge visuelle minimale, l'auditeur peut consulter l'historique
 # via le CTA "Voir mes réservations"). Si le commentaire est retiré (null),
 # un bloc explicite "Le message précédemment associé a été retiré" remplace
 # l'encadré.
 #
 # Le sujet de l'email est construit en PHP par
 # NotificationService::notifierAuditeurCommentaireCreneau(), pas via un
 # {% block subject %} dans ce template. Raison : le sujet intègre la date
 # formatée du créneau et doit être préfixable en mode redirection DEV
 # ("[DEV→destinataire] Mise à jour de votre rendez-vous — …"). Ce template
 # est responsable du body uniquement.
 #
 # Variables :
 #   auditeur_prenom         string                — pour la salutation
 #   personnel_nom_complet   string                — "Prénom Nom" (auteur de la modif)
 #   service_nom             ?string               — null si Personnel non rattaché (Super-admin)
 #   creneau_debut           \DateTimeInterface    — début du créneau (inchangé)
 #   creneau_fin             \DateTimeInterface    — fin du créneau (inchangé)
 #   commentaire_apres       ?string               — nouveau commentaire ; si null, bloc "retiré"
 #   lien_mes_reservations   string                — URL absolue
 #}

{% extends 'emails/_layout.html.twig' %}

{% block titre %}Mise à jour de votre rendez-vous — CreaSlot{% endblock %}

{% block sous_titre %}Mise à jour de votre rendez-vous{% endblock %}

{% block contenu %}

                            <p style="margin: 0 0 16px 0; color: #333333; font-size: 15px; font-family: Arial, sans-serif;">
                                Bonjour {{ auditeur_prenom }},
                            </p>

                            <p style="margin: 0 0 24px 0; color: #333333; font-size: 14px; line-height: 1.5; font-family: Arial, sans-serif;">
                                {{ personnel_nom_complet }} a mis à jour les informations concernant votre rendez-vous.
                            </p>

                            {# ── Encadré récap (bordure gauche bleu marine) ── #}
                            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"
                                   style="margin: 0 0 24px 0;">
                                <tr>
                                    <td style="background-color: #f8f9fa; border-left: 4px solid #1A3E6F; padding: 16px 20px; color: #333333; font-size: 14px; line-height: 1.6; font-family: Arial, sans-serif;">

                                        <p style="margin: 0 0 8px 0;">
                                            <strong style="color: #1A3E6F;">Date&nbsp;:</strong>
                                            {{ creneau_debut|format_date(locale='fr_FR', pattern='EEEE d MMMM y', timezone='Indian/Reunion')|capitalize }}
                                        </p>

                                        <p style="margin: 0 0 8px 0;">
                                            <strong style="color: #1A3E6F;">Horaire&nbsp;:</strong>
                                            {{ creneau_debut|date('H\\hi', 'Indian/Reunion') }} – {{ creneau_fin|date('H\\hi', 'Indian/Reunion') }}
                                        </p>

                                        {# ── Bloc message du personnel (si présent, sinon bloc "retiré") ── #}
                                        {% if commentaire_apres %}
                                        <p style="margin: 0 0 8px 0;">
                                            <strong style="color: #1A3E6F;">Message du personnel&nbsp;:</strong>
                                        </p>
                                        <p style="margin: 0 0 8px 0; padding: 12px 16px; background-color: #ffffff; border: 1px solid #ddd; border-radius: 4px; color: #333333; line-height: 1.6; font-style: italic;">
                                            {{ commentaire_apres|nl2br }}
                                        </p>
                                        {% else %}
                                        <p style="margin: 0 0 8px 0; color: #777777; font-style: italic;">
                                            Le message précédemment associé à ce rendez-vous a été retiré.
                                        </p>
                                        {% endif %}

                                        <p style="margin: 0 0 8px 0;">
                                            <strong style="color: #1A3E6F;">Avec&nbsp;:</strong>
                                            {{ personnel_nom_complet }}
                                        </p>

                                        {% if service_nom %}
                                        <p style="margin: 0 0 8px 0;">
                                            <strong style="color: #1A3E6F;">Service&nbsp;:</strong>
                                            {{ service_nom }}
                                        </p>
                                        {% endif %}

                                    </td>
                                </tr>
                            </table>

                            {# ── CTA "Voir mes réservations" ──────────────── #}
                            <table role="presentation" cellpadding="0" cellspacing="0" border="0"
                                   style="margin: 8px auto 16px auto;">
                                <tr>
                                    <td align="center" style="background-color: #1A3E6F; border-radius: 4px;">
                                        <a href="{{ lien_mes_reservations }}"
                                           style="display: inline-block; padding: 12px 28px; color: #ffffff; font-size: 14px; font-weight: bold; font-family: Arial, sans-serif; text-decoration: none;">
                                            Voir mes réservations
                                        </a>
                                    </td>
                                </tr>
                            </table>

                            <p style="margin: 0; color: #555555; font-size: 13px; line-height: 1.5; font-family: Arial, sans-serif;">
                                Pour toute question concernant ce message, vous pouvez contacter votre interlocuteur.
                            </p>

{% endblock %}
