{#
 # Template email — Réinitialisation de mot de passe (US-6.2).
 #
 # Envoyé via NotificationService::envoyer() (Brevo + redirection DEV + log). Le
 # sujet est construit côté PHP (préfixable en mode redirection DEV), ce template
 # n'est responsable que du corps.
 #
 # Minimisation RGPD : aucun nom ni donnée nominative, seulement le lien de
 # réinitialisation et sa durée de validité.
 #
 # Variables :
 #   resetToken  SymfonyCasts\Bundle\ResetPassword\Model\ResetPasswordToken
 #
 # Le lien est généré en URL absolue via url() (framework.router.default_uri),
 # comme les autres emails du projet.
 #}

{% extends 'emails/_layout.html.twig' %}

{% block titre %}Réinitialisation de mot de passe — CreaSlot{% endblock %}

{% block sous_titre %}Réinitialisation de mot de passe{% endblock %}

{% block contenu %}

                            <p style="margin: 0 0 16px 0; color: #333333; font-size: 15px; font-family: Arial, sans-serif;">
                                Bonjour,
                            </p>

                            <p style="margin: 0 0 24px 0; color: #333333; font-size: 14px; line-height: 1.5; font-family: Arial, sans-serif;">
                                Vous avez demandé la réinitialisation de votre mot de passe. Cliquez sur le bouton
                                ci-dessous pour en choisir un nouveau.
                            </p>

                            {# ── CTA "Réinitialiser" ───────────────────── #}
                            <table role="presentation" cellpadding="0" cellspacing="0" border="0"
                                   style="margin: 8px auto 24px auto;">
                                <tr>
                                    <td align="center" style="background-color: #1A3E6F; border-radius: 4px;">
                                        <a href="{{ url('app_mot_de_passe_oublie_reinitialiser', {token: resetToken.token}) }}"
                                           style="display: inline-block; padding: 12px 28px; color: #ffffff; font-size: 14px; font-weight: bold; font-family: Arial, sans-serif; text-decoration: none;">
                                            Réinitialiser mon mot de passe
                                        </a>
                                    </td>
                                </tr>
                            </table>

                            <p style="margin: 0 0 24px 0; color: #555555; font-size: 13px; line-height: 1.5; font-family: Arial, sans-serif;">
                                Ce lien expirera dans
                                {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}.
                                Si le bouton ne fonctionne pas, copiez-collez cette adresse dans votre navigateur&nbsp;:<br>
                                <span style="color: #1A3E6F; word-break: break-all;">{{ url('app_mot_de_passe_oublie_reinitialiser', {token: resetToken.token}) }}</span>
                            </p>

                            <p style="margin: 0; color: #555555; font-size: 13px; line-height: 1.5; font-family: Arial, sans-serif;">
                                Si vous n'êtes pas à l'origine de cette demande, ignorez simplement cet email : votre
                                mot de passe restera inchangé.
                            </p>

{% endblock %}
