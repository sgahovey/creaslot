{#
 # Template email — Confirmation d'annulation de réservation auditeur (US-4.3).
 #
 # Envoyé à l'Auditeur après annulation effective d'une de ses réservations.
 # Minimisation RGPD : prénom de l'auditeur (salutation), nom complet du
 # Personnel + service du créneau, RIEN d'autre (pas d'email/téléphone
 # Personnel exposé).
 #
 # ── Asymétrie volontaire sur le motif d'annulation ───────────────────────
 # - Ici (template Auditeur) : le motif EST affiché conditionnellement, car
 #   c'est l'auditeur LUI-MÊME qui l'a saisi (transparence de traitement de
 #   ses propres données, aucun risque RGPD à les lui retourner).
 # - Template Personnel symétrique : motif JAMAIS affiché ni même passé au
 #   contexte du template (minimisation : potentiellement données médicales
 #   ou sensibles, aucune utilité opérationnelle pour le Personnel).
 # - Cohérence avec US-4.2 : on n'a exposé ni email ni téléphone Auditeur
 #   côté Personnel ; le motif suit la même politique de minimisation.
 # Réf : US-4.3 audit section 3, dossier MSP3 section 6.6 Sécurité/RGPD.
 #
 # Le sujet de l'email est construit en PHP par
 # NotificationService::notifierAuditeurAnnulationReservation(), pas via un
 # {% block subject %} dans ce template. Raison : le sujet intègre la date
 # formatée du créneau et doit être préfixable en mode redirection DEV
 # ("[DEV→destinataire] Votre rendez-vous a été annulé — …"). Ce template
 # est responsable du body uniquement.
 #
 # Variables :
 #   auditeur_prenom        string                — pour la salutation
 #   creneau_debut          \DateTimeInterface    — début du créneau annulé
 #   creneau_fin            \DateTimeInterface    — fin du créneau annulé
 #   personnel_nom_complet  string                — "Prénom Nom"
 #   service_nom            ?string               — null si Personnel non rattaché (Super-admin)
 #   type_rdv_libelle       string                — "Présentiel" | "Visio" | "Téléphone"
 #   motif_annulation       ?string               — saisi par l'auditeur ; AFFICHAGE AUTORISÉ ici (cf. asymétrie supra)
 #   lien_mes_reservations  string                — URL absolue
 #}

{% extends 'emails/_layout.html.twig' %}

{% block titre %}Rendez-vous annulé — CreaSlot{% endblock %}

{% block sous_titre %}Annulation de rendez-vous{% endblock %}

{% block contenu %}

                            <p style="margin: 0 0 16px 0; color: #333333; font-size: 15px; font-family: Arial, sans-serif;">
                                Bonjour {{ auditeur_prenom }},
                            </p>

                            <p style="margin: 0 0 24px 0; color: #333333; font-size: 14px; line-height: 1.5; font-family: Arial, sans-serif;">
                                Nous avons bien enregistré l'annulation de votre rendez-vous. Vous trouverez ci-dessous le récapitulatif&nbsp;:
                            </p>

                            {# ── Encadré récap (bordure gauche bleu marine) ── #}
                            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"
                                   style="margin: 0 0 24px 0;">
                                <tr>
                                    <td style="background-color: #f8f9fa; border-left: 4px solid #1A3E6F; padding: 16px 20px; color: #333333; font-size: 14px; line-height: 1.6; font-family: Arial, sans-serif;">

                                        <p style="margin: 0 0 8px 0;">
                                            <strong style="color: #1A3E6F;">Date&nbsp;:</strong>
                                            {{ creneau_debut|format_date(locale='fr_FR', pattern='EEEE d MMMM y', timezone='Indian/Reunion')|capitalize }}
                                        </p>

                                        <p style="margin: 0 0 8px 0;">
                                            <strong style="color: #1A3E6F;">Horaire&nbsp;:</strong>
                                            {{ creneau_debut|date('H\\hi', 'Indian/Reunion') }} – {{ creneau_fin|date('H\\hi', 'Indian/Reunion') }}
                                        </p>

                                        <p style="margin: 0 0 8px 0;">
                                            <strong style="color: #1A3E6F;">Type&nbsp;:</strong>
                                            {{ type_rdv_libelle }}
                                        </p>

                                        <p style="margin: 0 0 8px 0;">
                                            <strong style="color: #1A3E6F;">Avec&nbsp;:</strong>
                                            {{ personnel_nom_complet }}
                                        </p>

                                        {% if service_nom %}
                                        <p style="margin: 0 0 8px 0;">
                                            <strong style="color: #1A3E6F;">Service&nbsp;:</strong>
                                            {{ service_nom }}
                                        </p>
                                        {% endif %}

                                    </td>
                                </tr>
                            </table>

                            {% if motif_annulation %}
                            {# ── Motif d'annulation que l'auditeur a saisi (transparence) ── #}
                            <p style="margin: 0 0 8px 0; color: #555555; font-size: 13px; font-family: Arial, sans-serif;">
                                Motif que vous avez indiqué&nbsp;:
                            </p>
                            <p style="margin: 0 0 24px 0; padding: 12px 16px; background-color: #f8f9fa; border-radius: 4px; color: #333333; font-size: 13px; line-height: 1.5; font-family: Arial, sans-serif; font-style: italic;">
                                {{ motif_annulation }}
                            </p>
                            {% endif %}

                            {# ── CTA "Voir mes réservations" ──────────────── #}
                            <table role="presentation" cellpadding="0" cellspacing="0" border="0"
                                   style="margin: 8px auto 16px auto;">
                                <tr>
                                    <td align="center" style="background-color: #1A3E6F; border-radius: 4px;">
                                        <a href="{{ lien_mes_reservations }}"
                                           style="display: inline-block; padding: 12px 28px; color: #ffffff; font-size: 14px; font-weight: bold; font-family: Arial, sans-serif; text-decoration: none;">
                                            Voir mes réservations
                                        </a>
                                    </td>
                                </tr>
                            </table>

                            <p style="margin: 0; color: #555555; font-size: 13px; line-height: 1.5; font-family: Arial, sans-serif;">
                                Vous pouvez à tout moment réserver un nouveau créneau depuis votre espace personnel.
                            </p>

{% endblock %}
