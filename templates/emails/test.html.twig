{#
 # Template email — Test de configuration mailer Brevo (US-4.1).
 #
 # Référence pour les futurs templates emails de l'itération 4 (confirmation
 # de réservation, annulation, etc.). Patterns appliqués :
 #  - Layout table-based (compatible Outlook, Gmail web, Apple Mail, iOS)
 #  - Styles 100% inline (les <style> et CSS externes sont strippés/ignorés
 #    par la majorité des clients mail)
 #  - role="presentation" sur les tables de mise en page (a11y emailing)
 #  - Max-width 600px (limite historique des clients mail)
 #  - Police Arial, sans-serif (fallback fiable cross-client, Helvetica sur Mac)
 #
 # Variables de contexte attendues :
 #   date_envoi    \DateTimeImmutable  — moment de l'envoi
#   (etiquette d'environnement lue depuis le global Twig app_environment_label)
 #}

{% block subject %}Test CreaSlot{% endblock %}

{% block body_html %}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Test CreaSlot</title>
</head>
<body style="margin: 0; padding: 0; font-family: Arial, sans-serif; background-color: #f8f9fa;">

    {# ── Wrapper centrant ─────────────────────────────────────────────── #}
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"
           style="background-color: #f8f9fa; padding: 24px 12px;">
        <tr>
            <td align="center">

                <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0"
                       style="max-width: 600px; width: 100%; background-color: #ffffff; border-radius: 8px; overflow: hidden;">

                    {# ── Header — bandeau bleu marine ─────────────────── #}
                    <tr>
                        <td style="background-color: #1a3e6f; padding: 24px; text-align: center;">
                            <p style="margin: 0; color: #ffffff; font-size: 24px; font-weight: bold; font-family: Arial, sans-serif; letter-spacing: 0.5px;">
                                CreaSlot
                            </p>
                        </td>
                    </tr>

                    {# ── Corps ────────────────────────────────────────── #}
                    <tr>
                        <td style="padding: 32px 24px;">

                            <h1 style="margin: 0 0 16px 0; color: #1a3e6f; font-size: 20px; font-weight: bold; font-family: Arial, sans-serif;">
                                Test de configuration mailer
                            </h1>

                            <p style="margin: 0 0 24px 0; color: #333333; font-size: 14px; line-height: 1.5; font-family: Arial, sans-serif;">
                                Cet email confirme que votre configuration Symfony Mailer fonctionne correctement avec Brevo.
                            </p>

                            {# Tableau récap des paramètres d'envoi #}
                            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"
                                   style="margin: 0 0 24px 0; border-collapse: collapse; border: 1px solid #e0e0e0; border-radius: 4px;">
                                <tr>
                                    <td style="padding: 12px 16px; background-color: #f8f9fa; color: #555555; font-size: 13px; font-family: Arial, sans-serif; border-bottom: 1px solid #e0e0e0; width: 40%;">
                                        <strong>Date d'envoi</strong>
                                    </td>
                                    <td style="padding: 12px 16px; background-color: #ffffff; color: #1a3e6f; font-size: 13px; font-family: Arial, sans-serif; border-bottom: 1px solid #e0e0e0;">
                                        {{ date_envoi|date('d/m/Y à H:i:s', 'Indian/Reunion') }}
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 12px 16px; background-color: #f8f9fa; color: #555555; font-size: 13px; font-family: Arial, sans-serif;">
                                        <strong>Environnement</strong>
                                    </td>
                                    <td style="padding: 12px 16px; background-color: #ffffff; color: #1a3e6f; font-size: 13px; font-weight: bold; font-family: Arial, sans-serif;">
                                        {{ app_environment_label|upper }}
                                    </td>
                                </tr>
                            </table>

                            <p style="margin: 0; color: #555555; font-size: 13px; line-height: 1.5; font-family: Arial, sans-serif;">
                                Si vous lisez ce message, la chaîne complète d'envoi (Symfony → Brevo → boîte de réception) fonctionne.
                            </p>

                        </td>
                    </tr>

                    {# ── Footer — bandeau gris ────────────────────────── #}
                    <tr>
                        <td style="background-color: #f8f9fa; padding: 16px 24px; text-align: center; border-top: 1px solid #e0e0e0;">
                            <p style="margin: 0 0 4px 0; color: #555555; font-size: 12px; font-family: Arial, sans-serif;">
                                CreaSlot — Application de gestion des rendez-vous
                            </p>
                            <p style="margin: 0; color: #999999; font-size: 11px; font-family: Arial, sans-serif;">
                                © 2026 Cnam Réunion
                            </p>
                        </td>
                    </tr>

                </table>

            </td>
        </tr>
    </table>

</body>
</html>
{% endblock %}
