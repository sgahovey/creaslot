{#
 # Template email — Notification au Personnel d'annulation de réservation (US-4.3).
 #
 # Envoyé au Personnel quand un Auditeur annule l'une de ses réservations
 # sur l'un de ses créneaux. Le créneau redevient disponible et pourra être
 # réservé par un autre auditeur (déclenchant alors un email "Nouveau
 # rendez-vous" US-4.2 si cela se produit).
 #
 # ── Asymétrie volontaire sur le motif d'annulation ───────────────────────
 # - Ici (template Personnel) : le motif d'annulation N'EST PAS affiché ni
 #   même passé au contexte du template (minimisation RGPD : il peut contenir
 #   des données médicales, raisons personnelles, autres infos sensibles ;
 #   aucune utilité opérationnelle pour le Personnel).
 # - Template Auditeur symétrique : motif AFFICHÉ conditionnellement, car
 #   c'est l'auditeur LUI-MÊME qui l'a saisi (transparence de traitement).
 # - Cohérence avec US-4.2 : on n'a exposé ni email ni téléphone Auditeur
 #   côté Personnel ; le motif suit la même politique de minimisation.
 # Réf : US-4.3 audit section 3, dossier MSP3 section 6.6 Sécurité/RGPD.
 #
 # Le sujet de l'email est construit en PHP par
 # NotificationService::notifierPersonnelAnnulationReservation(), pas via un
 # {% block subject %} dans ce template. Raison : le sujet intègre la date
 # formatée du créneau ET le nom de l'auditeur, et doit être préfixable en
 # mode redirection DEV ("[DEV→destinataire] Annulation par … — …").
 # Ce template est responsable du body uniquement.
 #
 # Variables :
 #   personnel_prenom       string                — pour la salutation
 #   auditeur_nom_complet   string                — "Prénom Nom" (identification nécessaire)
 #   auditeur_categorie     ?string               — catégorie pro (alternant, demandeur d'emploi, etc.) ; toujours null tant que le champ n'est pas implémenté (cf. décision A1 audit 3.1 US-4.2)
 #   creneau_debut          \DateTimeInterface
 #   creneau_fin            \DateTimeInterface
 #   type_rdv_libelle       string                — "Présentiel" | "Visio" | "Téléphone"
 #   lien_mon_agenda        string                — URL absolue vers l'agenda Personnel
 #
 # motif_annulation : VOLONTAIREMENT ABSENT du contexte (cf. asymétrie supra).
 #}

{% extends 'emails/_layout.html.twig' %}

{% block titre %}Annulation de rendez-vous — CreaSlot{% endblock %}

{% block sous_titre %}Annulation par un auditeur{% endblock %}

{% block contenu %}

                            <p style="margin: 0 0 16px 0; color: #333333; font-size: 15px; font-family: Arial, sans-serif;">
                                Bonjour {{ personnel_prenom }},
                            </p>

                            <p style="margin: 0 0 24px 0; color: #333333; font-size: 14px; line-height: 1.5; font-family: Arial, sans-serif;">
                                {{ auditeur_nom_complet }} a annulé sa réservation.
                            </p>

                            {# ── Encadré récap (bordure gauche bleu marine) ── #}
                            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"
                                   style="margin: 0 0 24px 0;">
                                <tr>
                                    <td style="background-color: #f8f9fa; border-left: 4px solid #1A3E6F; padding: 16px 20px; color: #333333; font-size: 14px; line-height: 1.6; font-family: Arial, sans-serif;">

                                        <p style="margin: 0 0 8px 0;">
                                            <strong style="color: #1A3E6F;">Date&nbsp;:</strong>
                                            {{ creneau_debut|format_date(locale='fr_FR', pattern='EEEE d MMMM y', timezone='Indian/Reunion')|capitalize }}
                                        </p>

                                        <p style="margin: 0 0 8px 0;">
                                            <strong style="color: #1A3E6F;">Horaire&nbsp;:</strong>
                                            {{ creneau_debut|date('H\\hi', 'Indian/Reunion') }} – {{ creneau_fin|date('H\\hi', 'Indian/Reunion') }}
                                        </p>

                                        <p style="margin: 0 0 8px 0;">
                                            <strong style="color: #1A3E6F;">Type&nbsp;:</strong>
                                            {{ type_rdv_libelle }}
                                        </p>

                                        <p style="margin: 0 0 8px 0;">
                                            <strong style="color: #1A3E6F;">Auditeur&nbsp;:</strong>
                                            {{ auditeur_nom_complet }}
                                        </p>

                                        {% if auditeur_categorie %}
                                        <p style="margin: 0 0 8px 0;">
                                            <strong style="color: #1A3E6F;">Catégorie&nbsp;:</strong>
                                            {{ auditeur_categorie }}
                                        </p>
                                        {% endif %}

                                    </td>
                                </tr>
                            </table>

                            {# ── CTA "Voir mon agenda" ────────────────────── #}
                            <table role="presentation" cellpadding="0" cellspacing="0" border="0"
                                   style="margin: 8px auto 16px auto;">
                                <tr>
                                    <td align="center" style="background-color: #1A3E6F; border-radius: 4px;">
                                        <a href="{{ lien_mon_agenda }}"
                                           style="display: inline-block; padding: 12px 28px; color: #ffffff; font-size: 14px; font-weight: bold; font-family: Arial, sans-serif; text-decoration: none;">
                                            Voir mon agenda
                                        </a>
                                    </td>
                                </tr>
                            </table>

                            <p style="margin: 0; color: #555555; font-size: 13px; line-height: 1.5; font-family: Arial, sans-serif;">
                                Le créneau est désormais disponible et peut être réservé par un autre auditeur.
                            </p>

{% endblock %}
