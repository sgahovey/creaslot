{#
 # Composant : carte d'une réservation (vue Auditeur)
 # Paramètres attendus :
 #   reservation  Reservation  — l'entité réservation à afficher
 #}

{% set creneau = reservation.creneau %}
{% set joursFR = ['Lundi','Mardi','Mercredi','Jeudi','Vendredi','Samedi','Dimanche'] %}
{% set nomJour = joursFR[creneau.dateDebut|date('N') - 1] %}

{# ── Statut (priorité stricte : ANNULEE > Passée > Active) ─────────── #}
{% if reservation.statut.value == 'ANNULEE' %}
    {% set badgeClass = 'text-bg-danger' %}
    {% set badgeLabel = 'Annulée' %}
    {% set badgeIcone = 'bi-x-circle' %}
{% elseif creneau.isPasse() %}
    {% set badgeClass = 'text-bg-secondary' %}
    {% set badgeLabel = 'Passée' %}
    {% set badgeIcone = 'bi-clock-history' %}
{% else %}
    {% set badgeClass = 'text-bg-success' %}
    {% set badgeLabel = 'Active' %}
    {% set badgeIcone = 'bi-check-circle' %}
{% endif %}

{% set peutAnnuler = reservation.statut.value == 'ACTIVE' and creneau.dateDebut > date() %}

<article class="card border-0 shadow-sm h-100"
         style="border-radius: var(--cs-radius-lg); border-left: 4px solid {{ creneau.typeRdv.couleurHex }} !important;"
         aria-label="Réservation {{ nomJour }} {{ creneau.dateDebut|date('d/m/Y') }} avec {{ creneau.utilisateur.prenom }} {{ creneau.utilisateur.nom }} — {{ badgeLabel }}">

    <div class="card-body p-3 d-flex flex-column gap-2">

        {# ── Ligne haute : type de RDV (gauche) + badge statut (droite) ──── #}
        <div class="d-flex align-items-start justify-content-between gap-2">
            <div class="d-flex align-items-center gap-2 min-w-0">
                <span class="rounded-circle flex-shrink-0"
                      aria-hidden="true"
                      style="width: 11px; height: 11px; background: {{ creneau.typeRdv.couleurHex }};"></span>
                <span class="fw-semibold text-truncate" style="font-size: .8125rem; color: var(--cs-text-secondary);">
                    {{ creneau.typeRdv.libelle }}
                </span>
            </div>
            <span class="badge {{ badgeClass }} d-flex align-items-center gap-1 flex-shrink-0 px-2 py-1">
                <i class="bi {{ badgeIcone }}" aria-hidden="true"></i>
                {{ badgeLabel }}
            </span>
        </div>

        {# ── Date et horaire ───────────────────────────────────────────── #}
        <p class="mb-0 fw-semibold" style="color: var(--cs-text-primary); font-size: .9375rem;">
            <i class="bi bi-calendar3 me-1" aria-hidden="true"></i>
            {{ nomJour }} {{ creneau.dateDebut|date('d/m/Y') }}
        </p>
        <p class="mb-0" style="font-size: .875rem; color: var(--cs-text-secondary);">
            <i class="bi bi-clock me-1" aria-hidden="true"></i>
            de {{ creneau.dateDebut|date('H\\hi') }} à {{ creneau.dateFin|date('H\\hi') }}
        </p>

        {# ── Personnel ─────────────────────────────────────────────────── #}
        <div class="d-flex align-items-center gap-2 mt-1">
            {% set initiales = creneau.utilisateur.prenom|first|upper ~ creneau.utilisateur.nom|first|upper %}
            <span class="cs-avatar flex-shrink-0"
                  aria-hidden="true"
                  style="width: 2rem; height: 2rem; font-size: .75rem;">
                {{ initiales }}
            </span>
            <div class="min-w-0">
                <p class="mb-0 fw-medium text-truncate" style="font-size: .875rem; color: var(--cs-text-primary);">
                    {{ creneau.utilisateur.prenom }} {{ creneau.utilisateur.nom|upper }}
                </p>
                {% if creneau.utilisateur.service %}
                    <p class="mb-0 text-truncate" style="font-size: .8rem; color: var(--cs-text-secondary);">
                        <i class="bi bi-building me-1" aria-hidden="true"></i>
                        {{ creneau.utilisateur.service.nom }}
                    </p>
                {% endif %}
            </div>
        </div>

        {# ── Commentaire de l'Auditeur (sa propre note lors de la réservation) ── #}
        {% if reservation.commentaireAuditeur %}
            <div class="mb-2">
                <small class="text-muted d-block">
                    <i class="bi bi-chat-left-text" aria-hidden="true"></i> Votre commentaire :
                </small>
                <p class="mb-0 small">{{ reservation.commentaireAuditeur|nl2br }}</p>
            </div>
        {% endif %}

        {# ── Commentaire du Personnel sur le créneau (précisions sur le RDV) ── #}
        {% if creneau.commentaireAuditeur %}
            <div class="mb-2">
                <small class="text-muted d-block">
                    <i class="bi bi-info-circle" aria-hidden="true"></i> Précisions du Personnel :
                </small>
                <p class="mb-0 small fst-italic">{{ creneau.commentaireAuditeur|nl2br }}</p>
            </div>
        {% endif %}

        {# ── Actions ───────────────────────────────────────────────────── #}
        <div class="d-flex gap-2 mt-auto pt-2 flex-wrap">
            {% if peutAnnuler %}
                <button type="button"
                        class="btn btn-sm btn-outline-danger d-flex align-items-center gap-1"
                        data-bs-toggle="modal"
                        data-bs-target="#modal-annuler-{{ reservation.id }}"
                        aria-label="Annuler la réservation du {{ nomJour }} {{ creneau.dateDebut|date('d/m/Y') }}">
                    <i class="bi bi-x-circle" aria-hidden="true"></i>
                    Annuler
                </button>
            {% endif %}
            <a href="{{ path('app_reservation_detail', { id: reservation.id }) }}"
               class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1"
               aria-label="Voir les détails de la réservation du {{ nomJour }} {{ creneau.dateDebut|date('d/m/Y') }}">
                <i class="bi bi-info-circle" aria-hidden="true"></i>
                Détails
            </a>
        </div>

    </div>
</article>

{% if peutAnnuler %}
    {% include 'components/modal_annulation_reservation.html.twig' with { reservation: reservation } only %}
{% endif %}
