{#
 # Composant : modale d'annulation de réservation (vue Auditeur)
 # Paramètre attendu :
 #   reservation  Reservation  — la réservation à annuler
 #
 # Couplage explicite avec App\Form\AnnulationReservationType :
 #   - Champ : annulation_reservation[motifAnnulation]
 #   - CSRF  : annulation_reservation[_token] (csrf_token_id = 'annulation_reservation')
 # Si le getBlockPrefix() du FormType change, mettre à jour ce composant.
 #}

{% set creneau  = reservation.creneau %}
{% set joursFR  = ['Lundi','Mardi','Mercredi','Jeudi','Vendredi','Samedi','Dimanche'] %}
{% set nomJour  = joursFR[creneau.dateDebut|date('N') - 1] %}
{% set modalId  = 'modal-annuler-' ~ reservation.id %}
{% set motifId  = 'motif-' ~ reservation.id %}

<div class="modal fade"
     id="{{ modalId }}"
     tabindex="-1"
     aria-labelledby="{{ modalId }}-titre"
     aria-modal="true"
     role="dialog">

    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow"
             style="border-radius: var(--cs-radius-lg);">

            {# ── En-tête ──────────────────────────────────────── #}
            <div class="modal-header border-0 pb-0">
                <h2 class="modal-title h6 fw-bold d-flex align-items-center gap-2"
                    id="{{ modalId }}-titre"
                    style="color: var(--cs-text-primary);">
                    <i class="bi bi-x-circle-fill text-danger" aria-hidden="true"></i>
                    Annuler ma réservation
                </h2>
                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"
                        aria-label="Fermer"></button>
            </div>

            {# ── Formulaire (englobe body + footer pour soumettre le motif) ───── #}
            <form action="{{ path('app_reservation_annulation', { id: reservation.id }) }}"
                  method="post"
                  novalidate>

                <div class="modal-body pt-2">

                    <p class="mb-3" style="color: var(--cs-text-primary);">
                        Vous êtes sur le point d'annuler la réservation suivante.
                        <strong>Cette action est irréversible.</strong>
                    </p>

                    {# Récap du créneau #}
                    <dl class="row mb-3 small" style="color: var(--cs-text-secondary);">
                        <dt class="col-5 fw-semibold">Date</dt>
                        <dd class="col-7">{{ nomJour }} {{ creneau.dateDebut|date('d/m/Y') }}</dd>

                        <dt class="col-5 fw-semibold">Horaires</dt>
                        <dd class="col-7">
                            {{ creneau.dateDebut|date('H\\hi') }} — {{ creneau.dateFin|date('H\\hi') }}
                        </dd>

                        <dt class="col-5 fw-semibold">Type de RDV</dt>
                        <dd class="col-7 d-flex align-items-center gap-2">
                            <span class="rounded-circle flex-shrink-0"
                                  aria-hidden="true"
                                  style="width: 10px; height: 10px; background: {{ creneau.typeRdv.couleurHex }};"></span>
                            {{ creneau.typeRdv.libelle }}
                        </dd>

                        <dt class="col-5 fw-semibold">Personnel</dt>
                        <dd class="col-7">
                            {{ creneau.utilisateur.prenom }} {{ creneau.utilisateur.nom|upper }}
                            {% if creneau.utilisateur.service %}
                                <br><span class="text-muted">{{ creneau.utilisateur.service.nom }}</span>
                            {% endif %}
                        </dd>
                    </dl>

                    {# Champ motif #}
                    <div class="mb-0">
                        <label for="{{ motifId }}" class="form-label fw-medium">
                            Motif (optionnel)
                        </label>
                        <textarea id="{{ motifId }}"
                                  name="annulation_reservation[motifAnnulation]"
                                  class="form-control"
                                  rows="3"
                                  maxlength="500"
                                  placeholder="Si vous le souhaitez, précisez la raison de votre annulation…"></textarea>
                        <div class="form-text">
                            Optionnel — vous pouvez préciser le motif de votre annulation.
                        </div>
                    </div>

                </div>

                {# ── Pied de page ─────────────────────────────── #}
                <div class="modal-footer border-0 pt-0 gap-2">

                    <input type="hidden"
                           name="annulation_reservation[_token]"
                           value="{{ csrf_token('annulation_reservation') }}">

                    <button type="button"
                            class="btn btn-outline-secondary"
                            data-bs-dismiss="modal">
                        Fermer
                    </button>

                    <button type="submit"
                            class="btn btn-danger d-flex align-items-center gap-1"
                            aria-label="Confirmer l'annulation de la réservation du {{ nomJour }} {{ creneau.dateDebut|date('d/m/Y') }}">
                        <i class="bi bi-x-circle" aria-hidden="true"></i>
                        Confirmer l'annulation
                    </button>

                </div>

            </form>

        </div>
    </div>
</div>
