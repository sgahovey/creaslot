{#
 # Composant : modal de confirmation de suppression d'un créneau
 # Paramètres attendus :
 #   creneau  Creneau  — l'entité créneau à supprimer
 #}

{% set estReserve = creneau.isReserve() %}
{% set modalId    = 'modal-suppr-' ~ creneau.id %}

<div class="modal fade"
     id="{{ modalId }}"
     tabindex="-1"
     aria-labelledby="{{ modalId }}-titre"
     aria-modal="true"
     role="dialog">

    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow"
             style="border-radius: var(--cs-radius-lg);">

            {# ── En-tête ──────────────────────────────────────── #}
            <div class="modal-header border-0 pb-0">
                <h2 class="modal-title h6 fw-bold d-flex align-items-center gap-2"
                    id="{{ modalId }}-titre"
                    style="color: var(--cs-text-primary);">
                    {% if estReserve %}
                        <i class="bi bi-exclamation-triangle-fill text-warning" aria-hidden="true"></i>
                        Suppression — créneau réservé
                    {% else %}
                        <i class="bi bi-trash3 text-danger" aria-hidden="true"></i>
                        Suppression d'un créneau
                    {% endif %}
                </h2>
                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"
                        aria-label="Fermer"></button>
            </div>

            {# ── Corps ────────────────────────────────────────── #}
            <div class="modal-body pt-2">

                {# Avertissement si créneau réservé #}
                {% if estReserve %}
                    <p class="mb-3" style="color: var(--cs-text-primary);">
                        <strong>ATTENTION</strong> — Ce créneau est réservé par
                        <strong>
                            {{ creneau.auditeurReservation.prenom }}
                            {{ creneau.auditeurReservation.nom }}
                        </strong>.
                        Sa suppression annulera également la réservation. Voulez-vous continuer ?
                    </p>
                    <div class="alert alert-warning d-flex align-items-start gap-2 mb-3"
                         role="alert">
                        <i class="bi bi-exclamation-triangle-fill flex-shrink-0 mt-1" aria-hidden="true"></i>
                        <span>La réservation de l'auditeur sera annulée automatiquement.</span>
                    </div>
                {% else %}
                    <p class="mb-3" style="color: var(--cs-text-primary);">
                        Voulez-vous vraiment supprimer ce créneau&nbsp;?
                    </p>
                {% endif %}

                {# Récapitulatif du créneau #}
                <dl class="row mb-0 small" style="color: var(--cs-text-secondary);">
                    <dt class="col-5 fw-semibold">Date</dt>
                    <dd class="col-7">{{ creneau.dateDebut|date('d/m/Y') }}</dd>

                    <dt class="col-5 fw-semibold">Horaires</dt>
                    <dd class="col-7">
                        {{ creneau.dateDebut|date('H\\hi') }} — {{ creneau.dateFin|date('H\\hi') }}
                    </dd>

                    <dt class="col-5 fw-semibold">Type de RDV</dt>
                    <dd class="col-7 d-flex align-items-center gap-2">
                        <span class="rounded-circle flex-shrink-0"
                              aria-hidden="true"
                              style="width: 10px; height: 10px; background: {{ creneau.typeRdv.couleurHex }};"></span>
                        {{ creneau.typeRdv.libelle }}
                    </dd>
                </dl>

            </div>

            {# ── Pied de page ─────────────────────────────────── #}
            <div class="modal-footer border-0 pt-0 gap-2">

                <button type="button"
                        class="btn btn-outline-secondary"
                        data-bs-dismiss="modal">
                    Annuler
                </button>

                <form action="{{ path('app_creneau_supprimer', { id: creneau.id }) }}"
                      method="post">
                    <input type="hidden"
                           name="_token"
                           value="{{ csrf_token('supprimer-creneau-' ~ creneau.id) }}">
                    <button type="submit"
                            class="btn btn-danger d-flex align-items-center gap-1"
                            aria-label="Confirmer la suppression du créneau du {{ creneau.dateDebut|date('d/m/Y') }}">
                        <i class="bi bi-trash3" aria-hidden="true"></i>
                        Confirmer la suppression
                    </button>
                </form>

            </div>

        </div>
    </div>
</div>
