<header class="cs-header" role="banner">
    <nav class="navbar navbar-expand-lg" style="background-color: var(--cs-blue-primary); padding: 0 var(--cs-space-lg);" aria-label="Navigation principale">
        <div class="container-fluid">

            {# Logo / nom de l'application #}
            <a class="navbar-brand d-flex align-items-center gap-2" href="{{ path('app_home') }}"
               style="color: var(--cs-text-light); font-weight: 700; font-size: 1.125rem; text-decoration: none;">
                <i class="bi bi-calendar-check-fill" aria-hidden="true"></i>
                CreaSlot
            </a>

            {# Bouton burger — mobile #}
            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse" data-bs-target="#cs-navbar"
                    aria-controls="cs-navbar" aria-expanded="false"
                    aria-label="Afficher/masquer le menu"
                    style="border-color: rgba(255,255,255,0.3);">
                <span class="navbar-toggler-icon" style="filter: invert(1);"></span>
            </button>

            <div class="collapse navbar-collapse" id="cs-navbar">
                <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">

                    {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                        {# Utilisateur connecté #}
                        <li class="nav-item">
                            <span class="navbar-text d-flex align-items-center gap-1"
                                  style="color: rgba(255,255,255,0.85); font-size: 0.9rem;">
                                <i class="bi bi-person-circle" aria-hidden="true"></i>
                                Bonjour, <strong>{{ app.user.prenom }}</strong>
                            </span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center gap-1"
                               href="{{ path('app_logout') }}"
                               style="color: rgba(255,255,255,0.75);">
                                <i class="bi bi-box-arrow-right" aria-hidden="true"></i>
                                Déconnexion
                            </a>
                        </li>
                    {% else %}
                        {# Utilisateur non connecté #}
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center gap-1"
                               href="{{ path('app_login') }}"
                               style="color: rgba(255,255,255,0.75);">
                                <i class="bi bi-box-arrow-in-right" aria-hidden="true"></i>
                                Se connecter
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-sm"
                               href="{{ path('app_inscription') }}"
                               style="background-color: rgba(255,255,255,0.15); color: var(--cs-text-light);
                                      border: 1px solid rgba(255,255,255,0.3); border-radius: var(--cs-radius-md);">
                                S'inscrire
                            </a>
                        </li>
                    {% endif %}

                </ul>
            </div>
        </div>
    </nav>
</header>
