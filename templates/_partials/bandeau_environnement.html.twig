{#
 # Bandeau de différenciation environnement
 #
 # Affiché automatiquement hors production via la variable Twig "pre_production"
 # (définie dans config/packages/twig.yaml depuis APP_PREPROD dans .env).
 #
 # - En développement local (APP_ENV=dev)          : bandeau bleu "DÉVELOPPEMENT"
 # - En pré-production (APP_ENVIRONMENT_LABEL=preprod) : bandeau orange "PRÉ-PRODUCTION"
 # - En production (APP_PREPROD=false, APP_ENV=prod)   : aucun bandeau
 #
 # Pour désactiver en production Railway : APP_PREPROD=false dans les variables Railway.
 #}
{% if app_environment_label is defined and app_environment_label == 'preprod' %}
    <div class="cs-env-banner cs-env-banner--preprod" role="status" aria-label="Environnement pré-production">
        <i class="bi bi-exclamation-triangle-fill" aria-hidden="true"></i>
        PRÉ-PRODUCTION — Les données de cet environnement ne sont pas réelles
    </div>
{% elseif app.environment == 'dev' %}
    <div class="cs-env-banner cs-env-banner--dev" role="status" aria-label="Environnement de développement">
        <i class="bi bi-code-slash" aria-hidden="true"></i>
        DÉVELOPPEMENT
    </div>
{% endif %}
