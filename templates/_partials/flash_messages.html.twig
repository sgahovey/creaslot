{# Flash messages Symfony — auto-dismiss après 5 secondes #}
{#
 # app.flashes consomme les messages à chaque appel : on l'appelle UNE SEULE
 # fois et on stocke tout dans allFlashes pour éviter que la détection vide
 # la session avant l'affichage.
 #}
{% set flash_config = {
    'success': { icon: 'bi-check-circle-fill',        bs_class: 'alert-success' },
    'info':    { icon: 'bi-info-circle-fill',          bs_class: 'alert-info'    },
    'warning': { icon: 'bi-exclamation-triangle-fill', bs_class: 'alert-warning' },
    'error':   { icon: 'bi-x-circle-fill',             bs_class: 'alert-danger'  }
} %}

{% set allFlashes = app.flashes %}

{% if allFlashes is not empty %}
<div class="container" id="cs-flash-container" style="padding-top: var(--cs-space-md);">
    {% for type, messages in allFlashes %}
        {% set config = flash_config[type] ?? { icon: 'bi-info-circle-fill', bs_class: 'alert-info' } %}
        {% for message in messages %}
            <div class="alert {{ config.bs_class }} alert-dismissible cs-alert fade show mb-2"
                 role="alert"
                 data-cs-autodismiss="5000">
                <i class="bi {{ config.icon }} flex-shrink-0" aria-hidden="true"></i>
                <span>{{ message }}</span>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer le message"></button>
            </div>
        {% endfor %}
    {% endfor %}
</div>

<script nonce="{{ csp_nonce('script') }}">
    (function () {
        document.querySelectorAll('[data-cs-autodismiss]').forEach(function (el) {
            var delay = parseInt(el.dataset.csAutodismiss, 10) || 5000;
            setTimeout(function () {
                var bsAlert = bootstrap.Alert.getOrCreateInstance(el);
                if (bsAlert) { bsAlert.close(); }
            }, delay);
        });
    })();
</script>
{% endif %}
