{% extends 'base.html.twig' %}

{% block title %}Détail de la réservation{% endblock %}

{% block body %}
<div class="container py-4" style="max-width: 720px;">

    {% set creneau  = reservation.creneau %}
    {% set joursFR  = ['Lundi','Mardi','Mercredi','Jeudi','Vendredi','Samedi','Dimanche'] %}
    {% set nomJour  = joursFR[creneau.dateDebut|date('N') - 1] %}

    {# ── Durée formatée : 1h / 1h30 / 2h05 / 45 min ───────────────────── #}
    {% set dureeMin     = ((creneau.dateFin|date('U')) - (creneau.dateDebut|date('U'))) // 60 %}
    {% set dureeHeures  = (dureeMin // 60) %}
    {% set dureeMinutes = dureeMin % 60 %}
    {% if dureeHeures > 0 %}
        {% set dureeAffiche = dureeHeures ~ 'h' ~ (dureeMinutes > 0 ? (dureeMinutes < 10 ? '0' ~ dureeMinutes : dureeMinutes) : '') %}
    {% else %}
        {% set dureeAffiche = dureeMinutes ~ ' min' %}
    {% endif %}

    {# ── Badge statut : priorité stricte ANNULEE > Passée > Active ────── #}
    {% if reservation.statut.value == 'ANNULEE' %}
        {% set badgeClass = 'text-bg-danger' %}
        {% set badgeLabel = 'Annulée' %}
        {% set badgeIcone = 'bi-x-circle' %}
    {% elseif creneau.isPasse() %}
        {% set badgeClass = 'text-bg-secondary' %}
        {% set badgeLabel = 'Passée' %}
        {% set badgeIcone = 'bi-clock-history' %}
    {% else %}
        {% set badgeClass = 'text-bg-success' %}
        {% set badgeLabel = 'Active' %}
        {% set badgeIcone = 'bi-check-circle' %}
    {% endif %}

    {# ── En-tête ─────────────────────────────────────────────────────── #}
    <div class="mb-4">
        <h1 class="h4 fw-bold mb-1" style="color: var(--cs-text-primary);">
            <i class="bi bi-calendar-check me-2" aria-hidden="true"></i>Détail de la réservation
        </h1>
        <p class="mb-0 d-flex align-items-center gap-2" style="font-size: .875rem; color: var(--cs-text-secondary);">
            <span class="rounded-circle flex-shrink-0"
                  aria-hidden="true"
                  style="width: 11px; height: 11px; background: {{ creneau.typeRdv.couleurHex }};"></span>
            {{ creneau.typeRdv.libelle }}
        </p>
    </div>

    {# ── Section 1 : Informations du créneau ─────────────────────────── #}
    <section class="card border-0 shadow-sm mb-3"
             style="border-radius: var(--cs-radius-lg); border-left: 4px solid {{ creneau.typeRdv.couleurHex }} !important;"
             aria-labelledby="section-creneau-titre">
        <div class="card-body p-4">
            <h2 id="section-creneau-titre"
                class="h6 fw-semibold mb-3 text-uppercase"
                style="color: var(--cs-text-secondary); letter-spacing: .04em; font-size: .75rem;">
                Informations du créneau
            </h2>

            <dl class="row mb-0 small" style="color: var(--cs-text-primary);">

                <dt class="col-sm-4 fw-semibold">Type de RDV</dt>
                <dd class="col-sm-8 d-flex align-items-center gap-2 mb-2">
                    <span class="rounded-circle flex-shrink-0"
                          aria-hidden="true"
                          style="width: 11px; height: 11px; background: {{ creneau.typeRdv.couleurHex }};"></span>
                    {{ creneau.typeRdv.libelle }}
                </dd>

                <dt class="col-sm-4 fw-semibold">Date</dt>
                <dd class="col-sm-8 mb-2">{{ nomJour }} {{ creneau.dateDebut|date('d/m/Y') }}</dd>

                <dt class="col-sm-4 fw-semibold">Horaires</dt>
                <dd class="col-sm-8 mb-2">
                    de {{ creneau.dateDebut|date('H\\hi') }} à {{ creneau.dateFin|date('H\\hi') }}
                    <span class="text-muted">({{ dureeAffiche }})</span>
                </dd>

                <dt class="col-sm-4 fw-semibold">Personnel</dt>
                <dd class="col-sm-8 mb-0">
                    {{ creneau.utilisateur.prenom }} {{ creneau.utilisateur.nom|upper }}
                    {% if creneau.utilisateur.service %}
                        <br>
                        <span class="text-muted">
                            <i class="bi bi-building me-1" aria-hidden="true"></i>
                            {{ creneau.utilisateur.service.nom }}
                        </span>
                    {% endif %}
                </dd>

            </dl>
        </div>
    </section>

    {# ── Section 2 : Mon commentaire ─────────────────────────────────── #}
    <section class="card border-0 shadow-sm mb-3"
             style="border-radius: var(--cs-radius-lg);"
             aria-labelledby="section-commentaire-titre">
        <div class="card-body p-4">
            <h2 id="section-commentaire-titre"
                class="h6 fw-semibold mb-3 text-uppercase"
                style="color: var(--cs-text-secondary); letter-spacing: .04em; font-size: .75rem;">
                <i class="bi bi-chat-left-text me-1" aria-hidden="true"></i>Mon commentaire
            </h2>
            {% if reservation.commentaireAuditeur %}
                <p class="mb-0 small" style="color: var(--cs-text-primary);">
                    {{ reservation.commentaireAuditeur|nl2br }}
                </p>
            {% else %}
                <p class="mb-0 small text-muted fst-italic">Aucun commentaire.</p>
            {% endif %}
        </div>
    </section>

    {# ── Section 3 : Précisions du Personnel (conditionnelle) ────────── #}
    {% if creneau.commentaireAuditeur %}
        <section class="card border-0 shadow-sm mb-3"
                 style="border-radius: var(--cs-radius-lg);"
                 aria-labelledby="section-precisions-titre">
            <div class="card-body p-4">
                <h2 id="section-precisions-titre"
                    class="h6 fw-semibold mb-3 text-uppercase"
                    style="color: var(--cs-text-secondary); letter-spacing: .04em; font-size: .75rem;">
                    <i class="bi bi-info-circle me-1" aria-hidden="true"></i>Précisions du Personnel
                </h2>
                <p class="mb-0 small fst-italic" style="color: var(--cs-text-primary);">
                    {{ creneau.commentaireAuditeur|nl2br }}
                </p>
            </div>
        </section>
    {% endif %}

    {# ── Section 4 : Statut ──────────────────────────────────────────── #}
    <section class="card border-0 shadow-sm mb-3"
             style="border-radius: var(--cs-radius-lg);"
             aria-labelledby="section-statut-titre">
        <div class="card-body p-4 d-flex align-items-center justify-content-between gap-3 flex-wrap">
            <h2 id="section-statut-titre"
                class="h6 fw-semibold mb-0 text-uppercase"
                style="color: var(--cs-text-secondary); letter-spacing: .04em; font-size: .75rem;">
                Statut
            </h2>
            <span class="badge {{ badgeClass }} d-flex align-items-center gap-1 px-3 py-2"
                  style="font-size: .875rem;">
                <i class="bi {{ badgeIcone }}" aria-hidden="true"></i>
                {{ badgeLabel }}
            </span>
        </div>
    </section>

    {# ── Section 5 : Informations d'annulation (conditionnelle) ──────── #}
    {% if reservation.statut.value == 'ANNULEE' %}
        <section class="card border-0 shadow-sm mb-3"
                 style="border-radius: var(--cs-radius-lg);"
                 aria-labelledby="section-annulation-titre">
            <div class="card-body p-4">
                <h2 id="section-annulation-titre"
                    class="h6 fw-semibold mb-3 text-uppercase"
                    style="color: var(--cs-text-secondary); letter-spacing: .04em; font-size: .75rem;">
                    <i class="bi bi-x-circle me-1" aria-hidden="true"></i>Informations d'annulation
                </h2>

                <dl class="row mb-0 small" style="color: var(--cs-text-primary);">

                    <dt class="col-sm-4 fw-semibold">Annulée le</dt>
                    <dd class="col-sm-8 mb-2">
                        {% if reservation.dateAnnulation %}
                            {% set nomJourAnnul = joursFR[reservation.dateAnnulation|date('N') - 1] %}
                            {{ nomJourAnnul }} {{ reservation.dateAnnulation|date('d/m/Y') }}
                            à {{ reservation.dateAnnulation|date('H\\hi') }}
                        {% else %}
                            <span class="text-muted fst-italic">Date inconnue</span>
                        {% endif %}
                    </dd>

                    <dt class="col-sm-4 fw-semibold">Motif</dt>
                    <dd class="col-sm-8 mb-0">
                        {% if reservation.motifAnnulation %}
                            {{ reservation.motifAnnulation|nl2br }}
                        {% else %}
                            <span class="text-muted fst-italic">Aucun motif n'a été indiqué.</span>
                        {% endif %}
                    </dd>

                </dl>
            </div>
        </section>
    {% endif %}

    {# ── Actions ─────────────────────────────────────────────────────── #}
    <div class="d-flex gap-2 flex-wrap mt-4">
        <a href="{{ path('app_mes_reservations') }}"
           class="btn btn-outline-secondary d-flex align-items-center gap-1"
           aria-label="Retour à la liste de mes réservations">
            <i class="bi bi-arrow-left" aria-hidden="true"></i>
            Retour
        </a>

        {% if reservation.isAnnulable() %}
            <button type="button"
                    class="btn btn-danger d-flex align-items-center gap-1"
                    data-bs-toggle="modal"
                    data-bs-target="#modal-annuler-{{ reservation.id }}"
                    aria-label="Annuler cette réservation">
                <i class="bi bi-x-circle" aria-hidden="true"></i>
                Annuler la réservation
            </button>
        {% endif %}
    </div>

    {# ── Modale d'annulation (réutilisée d'US-3.4) ────────────────────── #}
    {% if reservation.isAnnulable() %}
        {% include 'components/modal_annulation_reservation.html.twig' with { reservation: reservation } only %}
    {% endif %}

</div>
{% endblock %}
