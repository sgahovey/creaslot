{% extends 'base.html.twig' %}

{% block title %}Confirmer ma réservation{% endblock %}

{% block body %}
<div class="container py-4" style="max-width: 720px;">

    {# ── Fil d'Ariane ─────────────────────────────────────────────────── #}
    <nav aria-label="Fil d'Ariane" class="mb-4">
        <ol class="breadcrumb" style="font-size: .875rem;">
            <li class="breadcrumb-item">
                <a href="{{ path('app_home') }}" class="text-decoration-none">Accueil</a>
            </li>
            <li class="breadcrumb-item">
                <a href="{{ path('app_creneaux_disponibles') }}" class="text-decoration-none">Trouver un RDV</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Confirmer la réservation</li>
        </ol>
    </nav>

    {# ── Titre ────────────────────────────────────────────────────────── #}
    <h1 class="h4 fw-bold mb-4" style="color: var(--cs-text-primary);">
        <i class="bi bi-calendar-check me-2" aria-hidden="true"></i>Confirmer ma réservation
    </h1>

    {# ── Carte détails du créneau ─────────────────────────────────────── #}
    {% set joursFR = ['Lundi','Mardi','Mercredi','Jeudi','Vendredi','Samedi','Dimanche'] %}
    {% set nomJour = joursFR[creneau.dateDebut|date('N') - 1] %}

    <section class="card border-0 shadow-sm mb-4"
             style="border-radius: var(--cs-radius-lg); border-left: 4px solid {{ creneau.typeRdv.couleurHex }} !important;"
             aria-label="Détails du créneau">
        <div class="card-body p-4">

            <h2 class="h6 fw-semibold mb-3 text-uppercase" style="color: var(--cs-text-secondary); letter-spacing: .04em; font-size: .75rem;">
                Créneau sélectionné
            </h2>

            <div class="row g-3">

                {# Type de RDV #}
                <div class="col-12 col-sm-6">
                    <p class="mb-1" style="font-size: .8rem; color: var(--cs-text-secondary);">Type de RDV</p>
                    <p class="mb-0 fw-semibold d-flex align-items-center gap-2">
                        <span class="rounded-circle flex-shrink-0"
                              aria-hidden="true"
                              style="width: 11px; height: 11px; background: {{ creneau.typeRdv.couleurHex }};"></span>
                        {{ creneau.typeRdv.libelle }}
                    </p>
                </div>

                {# Date et horaire #}
                <div class="col-12 col-sm-6">
                    <p class="mb-1" style="font-size: .8rem; color: var(--cs-text-secondary);">Date et horaire</p>
                    <p class="mb-0 fw-semibold">
                        {{ nomJour }} {{ creneau.dateDebut|date('d/m/Y') }}
                    </p>
                    <p class="mb-0" style="font-size: .875rem; color: var(--cs-text-secondary);">
                        de {{ creneau.dateDebut|date('H\\hi') }} à {{ creneau.dateFin|date('H\\hi') }}
                    </p>
                </div>

                {# Personnel #}
                <div class="col-12 col-sm-6">
                    <p class="mb-1" style="font-size: .8rem; color: var(--cs-text-secondary);">Interlocuteur</p>
                    <p class="mb-0 fw-semibold">
                        {{ creneau.utilisateur.prenom }} {{ creneau.utilisateur.nom|upper }}
                    </p>
                    {% if creneau.utilisateur.service %}
                        <p class="mb-0" style="font-size: .875rem; color: var(--cs-text-secondary);">
                            <i class="bi bi-building me-1" aria-hidden="true"></i>
                            {{ creneau.utilisateur.service.nom }}
                        </p>
                    {% endif %}
                </div>

                {# Commentaire du Personnel #}
                {% if creneau.commentaireAuditeur %}
                    <div class="col-12">
                        <p class="mb-1" style="font-size: .8rem; color: var(--cs-text-secondary);">Note du Personnel</p>
                        <p class="mb-0 fst-italic" style="font-size: .875rem; color: var(--cs-text-primary);">
                            <i class="bi bi-chat-left-text me-1" aria-hidden="true"></i>
                            {{ creneau.commentaireAuditeur }}
                        </p>
                    </div>
                {% endif %}

            </div>
        </div>
    </section>

    {# ── Formulaire de confirmation ───────────────────────────────────── #}
    {{ form_start(formulaire, { attr: { novalidate: 'novalidate' } }) }}

        <div class="card border-0 shadow-sm mb-4 p-4"
             style="border-radius: var(--cs-radius-lg);">

            <h2 class="h6 fw-semibold mb-3 text-uppercase" style="color: var(--cs-text-secondary); letter-spacing: .04em; font-size: .75rem;">
                Votre demande
            </h2>

            <div class="mb-3">
                {{ form_label(formulaire.commentaireAuditeur, null, { label_attr: { class: 'form-label fw-medium' } }) }}
                {{ form_widget(formulaire.commentaireAuditeur) }}
                {{ form_help(formulaire.commentaireAuditeur) }}
                {{ form_errors(formulaire.commentaireAuditeur) }}
            </div>

        </div>

        {# ── Boutons d'action ─────────────────────────────────────────── #}
        <div class="d-flex gap-3 flex-wrap">
            <button type="submit"
                    class="btn btn-primary d-flex align-items-center gap-2"
                    aria-label="Confirmer la réservation de ce créneau">
                <i class="bi bi-check-lg" aria-hidden="true"></i>
                Confirmer la réservation
            </button>
            <a href="{{ path('app_creneaux_disponibles') }}"
               class="btn btn-outline-secondary d-flex align-items-center gap-2"
               aria-label="Annuler et retourner à la liste des créneaux">
                <i class="bi bi-x-lg" aria-hidden="true"></i>
                Annuler
            </a>
        </div>

    {{ form_end(formulaire) }}

</div>
{% endblock %}
