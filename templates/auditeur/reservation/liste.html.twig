{% extends 'base.html.twig' %}

{% block title %}Mes réservations{% endblock %}

{% block body %}
<div class="container py-4" style="max-width: 1100px;">

    {# ── En-tête ─────────────────────────────────────────────────────── #}
    <div class="mb-4">
        <h1 class="h4 fw-bold mb-1" style="color: var(--cs-text-primary);">
            <i class="bi bi-calendar-check me-2" aria-hidden="true"></i>Mes réservations
        </h1>
        <p class="text-muted mb-0" style="font-size: .875rem;" aria-live="polite" aria-atomic="true">
            {% if total == 0 %}
                Aucune réservation à afficher.
            {% elseif total == 1 %}
                1 réservation.
            {% else %}
                {{ total }} réservations.
            {% endif %}
        </p>
    </div>

    {# ── Barre de filtres ─────────────────────────────────────────────── #}
    {% set filtresDispo = [
        { key: 'toutes',   label: 'Toutes' },
        { key: 'a_venir',  label: 'À venir' },
        { key: 'passees',  label: 'Passées' },
        { key: 'annulees', label: 'Annulées' }
    ] %}
    <nav class="d-flex flex-wrap gap-2 mb-4" aria-label="Filtres des réservations">
        {% for f in filtresDispo %}
            {% set actif = f.key == filtreActif %}
            <a href="{{ path('app_mes_reservations', f.key == 'toutes' ? {} : { filtre: f.key }) }}"
               class="btn btn-sm {{ actif ? 'btn-primary' : 'btn-outline-primary' }}"
               {% if actif %}aria-current="page"{% endif %}>
                {{ f.label }}
            </a>
        {% endfor %}
    </nav>

    {# ── Liste ou état vide contextuel ─────────────────────────────────── #}
    {% if total == 0 %}

        {% set messagesVide = {
            'toutes':   "Vous n'avez aucune réservation pour le moment.",
            'a_venir':  "Aucune réservation à venir.",
            'passees':  "Aucune réservation passée.",
            'annulees': "Aucune réservation annulée."
        } %}
        {% set ctaTrouverVisible = filtreActif in ['toutes', 'a_venir'] %}

        <div class="text-center py-5 text-muted">
            <i class="bi bi-calendar-x fs-1 d-block mb-3" aria-hidden="true"></i>
            <p class="mb-3 fw-semibold">{{ messagesVide[filtreActif] }}</p>
            {% if ctaTrouverVisible %}
                <a href="{{ path('app_creneaux_disponibles') }}"
                   class="btn btn-primary d-inline-flex align-items-center gap-1">
                    <i class="bi bi-search" aria-hidden="true"></i>
                    Trouver un RDV
                </a>
            {% endif %}
        </div>

    {% else %}

        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3"
             aria-label="Liste de mes réservations">
            {% for reservation in reservations %}
                <div class="col">
                    {{ include('components/carte_reservation.html.twig', { reservation: reservation }) }}
                </div>
            {% endfor %}
        </div>

        {# ── Pagination ───────────────────────────────────────────────── #}
        {% if nbPages > 1 %}
            <nav class="mt-4" aria-label="Pagination des réservations">
                <ul class="pagination justify-content-center">

                    <li class="page-item {% if page == 1 %}disabled{% endif %}">
                        <a class="page-link"
                           href="{{ path('app_mes_reservations', { filtre: filtreActif, page: page - 1 }) }}"
                           aria-label="Page précédente"
                           {% if page == 1 %}aria-disabled="true" tabindex="-1"{% endif %}>
                            <i class="bi bi-chevron-left" aria-hidden="true"></i>
                        </a>
                    </li>

                    {% for p in 1..nbPages %}
                        <li class="page-item {% if p == page %}active{% endif %}"
                            {% if p == page %}aria-current="page"{% endif %}>
                            <a class="page-link"
                               href="{{ path('app_mes_reservations', { filtre: filtreActif, page: p }) }}">
                                {{ p }}
                            </a>
                        </li>
                    {% endfor %}

                    <li class="page-item {% if page == nbPages %}disabled{% endif %}">
                        <a class="page-link"
                           href="{{ path('app_mes_reservations', { filtre: filtreActif, page: page + 1 }) }}"
                           aria-label="Page suivante"
                           {% if page == nbPages %}aria-disabled="true" tabindex="-1"{% endif %}>
                            <i class="bi bi-chevron-right" aria-hidden="true"></i>
                        </a>
                    </li>

                </ul>
            </nav>
        {% endif %}

    {% endif %}

</div>
{% endblock %}
