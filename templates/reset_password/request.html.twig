{#
 # Demande de réinitialisation de mot de passe (US-6.2) — saisie de l'email.
 #}
{% extends 'base.html.twig' %}

{% form_theme requestForm 'bootstrap_5_layout.html.twig' %}

{% block title %}Mot de passe oublié{% endblock %}

{# Pages d'auth : masquer header, footer et flash (ils sont dans la carte) #}
{% block header %}{% endblock %}
{% block footer %}{% endblock %}
{% block flash_messages %}{% endblock %}

{% block body %}
<div class="cs-auth-wrapper">
    <div class="cs-auth-card">

        <div class="d-flex align-items-center gap-2 mb-4">
            <i class="bi bi-calendar-check-fill" style="font-size: 1.5rem; color: var(--cs-blue-primary);" aria-hidden="true"></i>
            <span class="cs-auth-logo">CreaSlot</span>
        </div>

        <h1 class="cs-auth-title">Mot de passe oublié</h1>
        <p class="cs-auth-subtitle">
            Saisissez votre adresse email : si un compte y est associé, vous recevrez un lien pour
            réinitialiser votre mot de passe.
        </p>

        {% for flash_error in app.flashes('reset_password_error') %}
            <div class="alert alert-danger d-flex align-items-center gap-2 mb-3" role="alert">
                <i class="bi bi-exclamation-triangle-fill" aria-hidden="true"></i>
                <span>{{ flash_error }}</span>
            </div>
        {% endfor %}

        {{ form_start(requestForm) }}
            {{ form_errors(requestForm) }}
            {{ form_row(requestForm.email) }}

            <div class="d-grid mt-4">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="bi bi-envelope" aria-hidden="true"></i>
                    Envoyer le lien de réinitialisation
                </button>
            </div>
        {{ form_end(requestForm) }}

        <div class="cs-auth-footer">
            <a href="{{ path('app_login') }}">Retour à la connexion</a>
        </div>

    </div>
</div>
{% endblock %}
