{#
 # Confirmation après une demande de réinitialisation (US-6.2).
 #
 # Message volontairement neutre (anti-énumération) : il ne révèle jamais si un
 # compte correspond à l'email saisi. Variable : resetToken (réel ou factice).
 #}
{% extends 'base.html.twig' %}

{% block title %}Email envoyé{% endblock %}

{% block header %}{% endblock %}
{% block footer %}{% endblock %}
{% block flash_messages %}{% endblock %}

{% block body %}
<div class="cs-auth-wrapper">
    <div class="cs-auth-card">

        <div class="d-flex align-items-center gap-2 mb-4">
            <i class="bi bi-calendar-check-fill" style="font-size: 1.5rem; color: var(--cs-blue-primary);" aria-hidden="true"></i>
            <span class="cs-auth-logo">CreaSlot</span>
        </div>

        <h1 class="cs-auth-title">Vérifiez vos emails</h1>

        <div class="alert alert-info d-flex align-items-start gap-2" role="alert">
            <i class="bi bi-envelope-check-fill mt-1" aria-hidden="true"></i>
            <span>
                Si un compte est associé à cette adresse, un email contenant un lien de
                réinitialisation vient d'être envoyé. Ce lien expirera dans
                {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}.
            </span>
        </div>

        <p class="text-secondary" style="font-size: var(--cs-fs-small);">
            Vous ne recevez rien ? Vérifiez vos courriers indésirables ou
            <a href="{{ path('app_mot_de_passe_oublie') }}">réessayez</a>.
        </p>

        <div class="cs-auth-footer">
            <a href="{{ path('app_login') }}">Retour à la connexion</a>
        </div>

    </div>
</div>
{% endblock %}
