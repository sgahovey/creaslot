{% extends 'base.html.twig' %}

{% block title %}Accès refusé (403){% endblock %}

{% block body %}
<main class="container" role="main" id="contenu-principal">
    <div class="cs-error-page">

        <div class="cs-error-icon" aria-hidden="true">
            <i class="bi bi-shield-lock"></i>
        </div>

        <h1 class="fw-bold mt-2 mb-1" style="color: var(--cs-text-primary); font-size: 1.75rem;">
            Accès refusé
        </h1>

        <p class="text-muted mb-1" style="font-size: .875rem; letter-spacing: .05em;">
            Erreur 403
        </p>

        <p class="text-muted mb-4" style="max-width: 440px;" role="status">
            Vous n'avez pas les droits nécessaires pour consulter cette page.
            {% if not is_granted('IS_AUTHENTICATED_FULLY') %}
                Connectez-vous avec un compte autorisé pour continuer.
            {% else %}
                Si vous pensez qu'il s'agit d'une erreur, contactez l'administrateur.
            {% endif %}
        </p>

        <div class="d-flex gap-3 flex-wrap justify-content-center">
            <a href="{{ path('app_home') }}"
               class="btn cs-btn-primary d-inline-flex align-items-center gap-2">
                <i class="bi bi-house-fill" aria-hidden="true"></i>
                Retour à l'accueil
            </a>
            {% if not is_granted('IS_AUTHENTICATED_FULLY') %}
                <a href="{{ path('app_login') }}"
                   class="btn cs-btn-secondary d-inline-flex align-items-center gap-2">
                    <i class="bi bi-box-arrow-in-right" aria-hidden="true"></i>
                    Se connecter
                </a>
            {% endif %}
        </div>

    </div>
</main>
{% endblock %}
