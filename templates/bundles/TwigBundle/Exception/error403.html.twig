{% extends 'base.html.twig' %}

{% block title %}Accès refusé (403){% endblock %}

{% block body %}
<div class="container">
    <div class="cs-error-page">

        <div class="cs-error-icon">
            <i class="bi bi-shield-lock" aria-hidden="true"></i>
        </div>

        <div class="cs-error-code" aria-hidden="true">403</div>

        <h1 class="fw-bold mt-2 mb-2" style="color: var(--cs-text-primary); font-size: 1.75rem;">
            Accès refusé
        </h1>
        <p class="text-muted mb-4" style="max-width: 420px;">
            Vous n'avez pas les droits nécessaires pour accéder à cette page.
            Connectez-vous ou contactez l'administrateur si vous pensez qu'il s'agit d'une erreur.
        </p>

        <div class="d-flex gap-3 flex-wrap justify-content-center">
            <a href="{{ path('app_home') }}" class="btn cs-btn-primary d-inline-flex align-items-center gap-2">
                <i class="bi bi-house-fill" aria-hidden="true"></i>
                Retour à l'accueil
            </a>
            {% if not is_granted('IS_AUTHENTICATED_FULLY') %}
                <a href="{{ path('app_login') }}" class="btn cs-btn-secondary d-inline-flex align-items-center gap-2">
                    <i class="bi bi-box-arrow-in-right" aria-hidden="true"></i>
                    Se connecter
                </a>
            {% endif %}
        </div>

    </div>
</div>
{% endblock %}
