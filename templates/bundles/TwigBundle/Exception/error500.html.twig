{% extends 'base.html.twig' %}

{% block title %}Erreur serveur (500){% endblock %}

{% block body %}
<div class="container">
    <div class="cs-error-page">

        <div class="cs-error-icon">
            <i class="bi bi-exclamation-triangle" aria-hidden="true"></i>
        </div>

        <div class="cs-error-code" aria-hidden="true">500</div>

        <h1 class="fw-bold mt-2 mb-2" style="color: var(--cs-text-primary); font-size: 1.75rem;">
            Une erreur technique est survenue
        </h1>
        <p class="text-muted mb-4" style="max-width: 440px;">
            Nous avons rencontré un problème inattendu. Nos équipes ont été notifiées.
            Veuillez réessayer dans quelques instants.
        </p>

        <a href="{{ path('app_home') }}" class="btn cs-btn-primary d-inline-flex align-items-center gap-2">
            <i class="bi bi-house-fill" aria-hidden="true"></i>
            Retour à l'accueil
        </a>

    </div>
</div>
{% endblock %}
