{% extends 'base.html.twig' %}

{% block title %}Page introuvable (404){% endblock %}

{% block body %}
<div class="container">
    <div class="cs-error-page">

        <div class="cs-error-icon">
            <i class="bi bi-question-circle" aria-hidden="true"></i>
        </div>

        <div class="cs-error-code" aria-hidden="true">404</div>

        <h1 class="fw-bold mt-2 mb-2" style="color: var(--cs-text-primary); font-size: 1.75rem;">
            Cette page n'existe pas
        </h1>
        <p class="text-muted mb-4" style="max-width: 420px;">
            La page que vous recherchez est introuvable. Elle a peut-être été déplacée ou supprimée.
        </p>

        <a href="{{ path('app_home') }}" class="btn cs-btn-primary d-inline-flex align-items-center gap-2">
            <i class="bi bi-house-fill" aria-hidden="true"></i>
            Retour à l'accueil
        </a>

    </div>
</div>
{% endblock %}
