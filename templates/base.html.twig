<!DOCTYPE html>
<html lang="fr" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="CreaSlot — Gestion de rendez-vous pour le Cnam Réunion">
    <title>{% block title %}CreaSlot{% endblock %} — CreaSlot</title>

    {# Google Fonts — Inter (design-tokens.md : famille de police principale) #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    {# Bootstrap 5 via CDN #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    {# Bootstrap Icons #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    {# Design system CreaSlot — variables --cs-* et classes utilitaires cs-* #}
    <link rel="stylesheet" href="/css/creaslot.css">

    {% block stylesheets %}{% endblock %}
</head>
<body class="cs-body">

    {# Bandeau environnement (preprod/dev) #}
    {% include '_partials/bandeau_environnement.html.twig' %}

    {# Header — les pages d'auth surchargent ce block pour le masquer #}
    {% block header %}
        {% include '_partials/header.html.twig' %}
    {% endblock %}

    <main class="cs-main" id="cs-main-content">

        {# Flash messages — peut être surchargé par un template enfant #}
        {% block flash_messages %}
            {% include '_partials/flash_messages.html.twig' %}
        {% endblock %}

        {% block body %}{% endblock %}

    </main>

    {# Footer — les pages d'auth surchargent ce block pour le masquer #}
    {% block footer %}
        {% include '_partials/footer.html.twig' %}
    {% endblock %}

    {# Bootstrap JS #}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    {% block javascripts %}{% endblock %}

</body>
</html>
