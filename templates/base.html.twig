<!DOCTYPE html>
<html lang="fr" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="CreaSlot — Gestion de rendez-vous pour le Cnam Réunion">
    {%- set _page_title -%}{% block title %}{% endblock %}{%- endset -%}
    <title>{% if pre_production is defined and pre_production %}[PRÉPROD] {% endif %}{% if _page_title|trim is not empty %}{{ _page_title|trim }} — {% endif %}CreaSlot</title>

    {# Police Inter — self-hostée (DT-13), remplace Google Fonts #}
    <link rel="stylesheet" href="{{ asset('vendor/inter/inter.css') }}">

    {# Bootstrap 5 — CSS self-hosté (DT-13), avant creaslot.css pour préserver la cascade #}
    <link rel="stylesheet" href="{{ asset('vendor/bootstrap/bootstrap.min.css') }}">

    {# Bootstrap Icons — CSS + polices self-hostés (DT-13) #}
    <link rel="stylesheet" href="{{ asset('vendor/bootstrap-icons/bootstrap-icons.css') }}">

    {# Design system CreaSlot — variables --cs-* et classes utilitaires cs-* #}
    <link rel="stylesheet" href="/css/creaslot.css">

    {% block stylesheets %}{% endblock %}

    {# AssetMapper — boote l'application Stimulus (entrypoint app.js) #}
    {{ importmap('app') }}
</head>
<body class="cs-body {% if pre_production is defined and pre_production %}cs-env-preprod{% else %}cs-env-prod{% endif %}">

    {# Bandeau environnement (preprod/dev) #}
    {% include '_partials/bandeau_environnement.html.twig' %}

    {# Header — les pages d'auth surchargent ce block pour le masquer #}
    {% block header %}
        {% include '_partials/header.html.twig' %}
    {% endblock %}

    <main class="cs-main" id="cs-main-content">

        {# Flash messages — peut être surchargé par un template enfant #}
        {% block flash_messages %}
            {% include '_partials/flash_messages.html.twig' %}
        {% endblock %}

        {% block body %}{% endblock %}

    </main>

    {# Footer — les pages d'auth surchargent ce block pour le masquer #}
    {% block footer %}
        {% include '_partials/footer.html.twig' %}
    {% endblock %}

    {# Bootstrap JS : self-hosté via importmap (importé dans app.js, cf. DT-13). #}

    {% block javascripts %}{% endblock %}

</body>
</html>
