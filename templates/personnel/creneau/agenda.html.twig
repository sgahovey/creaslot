{% extends 'base.html.twig' %}

{% block title %}Mon agenda{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* ── Maquette agenda CreaSlot (FullCalendar) ─────────────────── */
        .cs-agenda-page .cs-agenda-actions .btn.cs-btn-agenda-new {
            background-color: var(--cs-blue-primary);
            border-color: var(--cs-blue-primary);
            color: var(--cs-text-light);
            font-weight: var(--cs-fw-semibold);
        }
        .cs-agenda-page .cs-agenda-actions .btn.cs-btn-agenda-new:hover {
            filter: brightness(1.06);
            color: var(--cs-text-light);
        }

        #calendar.cs-fc-shell {
            min-height: 62vh;
        }

        .cs-fc-calendar-wrap {
            position: relative;
            min-height: 62vh;
        }

        .cs-agenda-empty-overlay {
            position: absolute;
            inset: 0;
            z-index: 12;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: var(--cs-space-md);
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(2px);
            border-radius: var(--cs-radius-lg);
            text-align: center;
        }

        .cs-agenda-empty-overlay[hidden] {
            display: none !important;
        }

        .cs-agenda-empty-card {
            max-width: 320px;
            padding: var(--cs-space-lg);
            border-radius: var(--cs-radius-lg);
            background-color: var(--cs-bg-subtle);
        }

        /* Info flash JS (sans dépendance Toast Bootstrap) */
        .cs-agenda-flash-live {
            position: fixed;
            top: var(--cs-space-lg);
            right: var(--cs-space-lg);
            z-index: 1086;
            max-width: min(340px, 92vw);
        }

        /* Barre d'outils : flèches + date sur une même ligne au centre */
        .cs-agenda-page .fc .fc-toolbar.fc-header-toolbar {
            flex-wrap: wrap;
            flex-direction: row;
            align-items: center;
            justify-content: space-between;
            gap: var(--cs-space-md);
            margin-bottom: var(--cs-space-md);
        }
        .cs-agenda-page .fc .fc-toolbar-chunk {
            display: flex !important;
            flex-direction: row !important;
            flex-wrap: wrap;
            align-items: center !important;
            gap: var(--cs-space-xs);
        }
        /* Centre : précédent, titre, suivant sans retour vertical */
        .cs-agenda-page .fc .fc-toolbar-chunk:nth-child(2) {
            justify-content: center;
            flex-wrap: nowrap !important;
            gap: var(--cs-space-sm);
        }
        .cs-agenda-page .fc .fc-toolbar-chunk:nth-child(2) .fc-button-group {
            flex-direction: row !important;
            gap: var(--cs-space-xs);
        }
        .cs-agenda-page .fc .fc-toolbar-chunk:nth-child(2) .fc-prev-button,
        .cs-agenda-page .fc .fc-toolbar-chunk:nth-child(2) .fc-next-button {
            flex: 0 0 auto !important;
        }
        .cs-agenda-page .fc .fc-toolbar-title {
            margin: 0 !important;
            padding: 0 var(--cs-space-xs);
            white-space: nowrap;
            line-height: 1.25;
            display: inline-block;
        }

        .cs-agenda-page .fc .fc-toolbar-chunk:first-child .fc-button-group {
            gap: 0;
        }
        .cs-agenda-page .fc .fc-button {
            border-radius: var(--cs-radius-md) !important;
            font-weight: var(--cs-fw-medium);
        }
        .cs-agenda-page .fc .fc-button-primary:not(:disabled):not(.fc-button-active),
        .cs-agenda-page .fc .fc-button:not(.fc-button-active):not(:disabled) {
            background-color: var(--cs-bg-subtle);
            border-color: var(--cs-border);
            color: var(--cs-text-primary);
        }
        .cs-agenda-page .fc .fc-button-primary:not(:disabled).fc-button-active,
        .cs-agenda-page .fc .fc-button-primary:not(:disabled):hover,
        .cs-agenda-page .fc .fc-button:not(.fc-button-active):not(:disabled):hover {
            background-color: var(--cs-blue-primary) !important;
            border-color: var(--cs-blue-primary) !important;
            color: var(--cs-text-light) !important;
        }

        /* Pause déjeuner — bandeau sous les créneaux (non cliquable, pointer-events: none en JS) */
        .cs-fc-pause-dejeuner {
            border: none !important;
            background: repeating-linear-gradient(
                -45deg,
                #e9ecef,
                #e9ecef 5px,
                #f8f9fa 5px,
                #f8f9fa 10px
            ) !important;
            box-shadow: none !important;
            z-index: 0 !important;
        }
        .cs-fc-pause-dejeuner .fc-event-main {
            color: var(--cs-text-secondary) !important;
            font-size: var(--cs-fs-small);
            font-weight: var(--cs-fw-semibold);
            justify-content: center;
            letter-spacing: 0.06em;
        }

        .cs-agenda-page .fc-v-event.cs-fc-creneau {
            z-index: 2;
        }
        .cs-agenda-page .fc-v-event.cs-fc-creneau .fc-event-main {
            border-radius: var(--cs-radius-md);
            padding: 2px 4px;
        }

        /* Légende */
        .cs-agenda-legende {
            border-top: 1px solid var(--cs-border);
            margin-top: var(--cs-space-md);
            padding-top: var(--cs-space-md);
            font-size: var(--cs-fs-small);
            color: var(--cs-text-secondary);
        }
        .cs-agenda-legende .cs-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            display: inline-block;
            vertical-align: middle;
        }
    </style>
{% endblock %}

{% block body %}
<div class="container py-4 cs-agenda-page"
     id="agenda-root"
     data-controller="agenda"
     data-agenda-url-api-value="{{ path('api_creneaux_personnel') }}"
     data-agenda-url-next-reserved-value="{{ path('api_creneaux_next_reserved') }}"
     data-agenda-url-modifier-modele-value="{{ path('app_creneau_modifier', { id: '__ID__' }) }}">

    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-2">
        <h1 class="h3 fw-bold mb-0" style="color: var(--cs-text-primary);">
            Mon agenda
        </h1>
        <div class="d-flex flex-wrap gap-2 cs-agenda-actions">
            <a href="{{ path('app_creneau_liste') }}" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-list-ul me-1" aria-hidden="true"></i>Liste complète
            </a>
            <a href="{{ path('app_creneau_nouveau') }}" class="btn btn-sm cs-btn-agenda-new">
                <i class="bi bi-plus-lg me-1" aria-hidden="true"></i>Nouveau créneau
            </a>
        </div>
    </div>

    <nav aria-label="Fil d'Ariane" class="mb-3">
        <ol class="breadcrumb mb-0 py-1" style="font-size: .8125rem;">
            <li class="breadcrumb-item">
                <a href="{{ path('app_home') }}" style="color: var(--cs-blue-primary);">Accueil</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Mon agenda</li>
        </ol>
    </nav>

    <p class="text-muted small mb-3 lh-base">
        Cette vue affiche par défaut uniquement vos rendez-vous réservés.<br>
        Activez le toggle pour voir aussi vos créneaux libres.
    </p>

    <div class="form-check form-switch mb-3">
        <input class="form-check-input" type="checkbox" role="switch"
               id="toggleDisponibilites" name="toggleDisponibilites"
               data-agenda-target="toggle"
               data-action="change->agenda#onToggleDispo"
               aria-describedby="toggleDisponibilites-help">
        <label class="form-check-label" for="toggleDisponibilites">
            Afficher aussi les créneaux libres
        </label>
        <p id="toggleDisponibilites-help" class="form-text small text-muted mb-0 mt-1">
            Par défaut, seuls les rendez-vous réservés sont visibles.
        </p>
    </div>

    <div class="card border-0 shadow-sm p-2 p-md-3 cs-fc-calendar-shell"
         style="border-radius: var(--cs-radius-lg);">
        <div id="cs-fc-calendar-wrap" class="cs-fc-calendar-wrap position-relative">
            <div id="calendar"
                 class="cs-fc-shell"
                 data-agenda-target="calendar"
                 role="region"
                 aria-label="Calendrier des créneaux"></div>
            <div id="cs-agenda-empty-overlay"
                 class="cs-agenda-empty-overlay"
                 data-agenda-target="emptyOverlay"
                 hidden
                 role="status"
                 aria-live="polite"
                 aria-label="Aucun créneau affiché sur la période visible">
                <div class="cs-agenda-empty-card shadow-sm border-0 mx-auto">
                    <p class="small text-muted mb-3 mb-md-4">
                        Aucun créneau sur la période affichée.
                    </p>
                    <div class="d-flex flex-wrap gap-2 justify-content-center align-items-center">
                        <button type="button"
                                id="cs-agenda-empty-next"
                                class="btn btn-sm btn-outline-primary"
                                data-action="click->agenda#allerSuivant">
                            Suivant
                            <i class="bi bi-chevron-right ms-1" aria-hidden="true"></i>
                        </button>
                        <button type="button"
                                id="cs-agenda-empty-today"
                                class="btn btn-sm btn-primary"
                                data-action="click->agenda#allerAujourdhui">
                            Aujourd'hui
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="cs-agenda-legende d-flex flex-column gap-2 mt-3">
        <div class="d-flex flex-wrap align-items-center gap-3 justify-content-center justify-content-md-start">
            <span class="fw-semibold text-secondary">Légende :</span>
            {% for type in typesRdv %}
                <span><span class="cs-dot me-1" style="background: {{ type.couleurHex }};" aria-hidden="true"></span>{{ type.libelle }}</span>
            {% endfor %}
            <span class="text-muted ms-md-2 d-none d-md-inline">|</span>
            <span><strong>Cellule pleine</strong> = rendez-vous réservé</span>
            <span><strong>Cellule claire</strong> = créneau libre</span>
        </div>
        <p class="small text-muted mb-0">
            Vue semaine : <strong>lundi au vendredi</strong>. Grille <strong>8h30–17h00</strong>.
            Pause déjeuner affichée <strong>12h30–13h30</strong>. Les pastilles reflètent le type de rendez-vous.
        </p>
    </div>

    {# Modal détail créneau — placée dans la racine du contrôleur pour que les targets résolvent #}
    <div class="modal fade"
         id="creneau-detail-modal"
         data-agenda-target="modal"
         tabindex="-1"
         aria-labelledby="creneau-detail-modal-titre"
         aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow" style="border-radius: var(--cs-radius-lg);">
                <div class="modal-header border-0 pb-0">
                    <h2 class="modal-title h6 fw-bold" id="creneau-detail-modal-titre"
                        data-agenda-target="modalTitre" style="color: var(--cs-text-primary);">
                        Détail du créneau
                    </h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer la fenêtre"></button>
                </div>
                <div class="modal-body pt-2 small">
                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-muted">Type</dt>
                        <dd class="col-sm-8" data-agenda-target="modalType"></dd>
                        <dt class="col-sm-4 text-muted">Date</dt>
                        <dd class="col-sm-8" data-agenda-target="modalDate"></dd>
                        <dt class="col-sm-4 text-muted">Horaires</dt>
                        <dd class="col-sm-8" data-agenda-target="modalHoraires"></dd>
                        <dt class="col-sm-4 text-muted">Statut</dt>
                        <dd class="col-sm-8" data-agenda-target="modalStatut"></dd>
                        <dt class="col-sm-4 text-muted">Auditeur</dt>
                        <dd class="col-sm-8" data-agenda-target="modalAuditeur"></dd>
                        <dt class="col-sm-4 text-muted">Note</dt>
                        <dd class="col-sm-8" data-agenda-target="modalCommentaire"></dd>
                        <dt class="col-sm-4 text-muted">Motif auditeur</dt>
                        <dd class="col-sm-8" data-agenda-target="modalMotifAuditeur"></dd>
                    </dl>
                </div>
                <div class="modal-footer border-0 flex-wrap gap-2">
                    <a href="#" class="btn btn-sm btn-outline-secondary" data-agenda-target="lienModifier">
                        <i class="bi bi-pencil me-1" aria-hidden="true"></i>Modifier
                    </a>
                    <a href="{{ path('app_creneau_liste') }}" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-list-ul me-1" aria-hidden="true"></i>Voir la liste complète
                    </a>
                    <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Fermer</button>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {# FullCalendar v6 — bundle global officiel (core + plugins + preact en un seul fichier).
       Scripts CLASSIQUES (pas l'importmap) : le bundle déclare `var FullCalendar` au niveau
       global, ce qui n'expose window.FullCalendar que pour un <script> classique. Ils
       s'exécutent avant le module Stimulus différé, donc window.FullCalendar est prêt au
       connect() du contrôleur agenda. Le bundle d'abord, puis la locale (qui s'enregistre
       dans FullCalendar.globalLocales). #}
    <script src="{{ asset('vendor/fullcalendar/index.global.min.js') }}"></script>
    <script src="{{ asset('vendor/fullcalendar/locales/fr.global.min.js') }}"></script>
{% endblock %}
