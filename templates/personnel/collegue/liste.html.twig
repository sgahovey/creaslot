{% extends 'base.html.twig' %}

{% block title %}Mes collègues - CreaSlot{% endblock %}

{% block body %}
<div class="container py-4" style="max-width: 1100px;">

    {# ── En-tête de page ─────────────────────────────────────────────── #}
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
        <h1 class="h4 fw-bold mb-0" style="color: var(--cs-text-primary);">
            <i class="bi bi-people-fill me-2" aria-hidden="true"></i>Mes collègues
        </h1>
    </div>

    {# ── Filtres ─────────────────────────────────────────────────────── #}
    <div class="d-flex flex-wrap gap-2 mb-4" role="group" aria-label="Filtrer les collègues">

        {# Tous #}
        <a href="{{ path('app_collegues_liste') }}"
           class="btn btn-sm d-flex align-items-center gap-1
                  {% if not filtreMonService and not disponibles %}btn-primary{% else %}btn-outline-secondary{% endif %}"
           aria-current="{{ not filtreMonService and not disponibles ? 'true' : 'false' }}">
            <i class="bi bi-list-ul" aria-hidden="true"></i>
            Tous
        </a>

        {# Mon service — seulement si le Personnel connecté appartient à un service #}
        {% if aUnService %}
            <a href="{{ path('app_collegues_liste', { 'mon-service': '1' }) }}"
               class="btn btn-sm d-flex align-items-center gap-1
                      {% if filtreMonService and not disponibles %}btn-primary{% else %}btn-outline-secondary{% endif %}"
               aria-current="{{ filtreMonService and not disponibles ? 'true' : 'false' }}">
                <i class="bi bi-building" aria-hidden="true"></i>
                Mon service
            </a>
        {% endif %}

        {# Disponibles maintenant #}
        <a href="{{ path('app_collegues_liste', { disponibles: '1' }) }}"
           class="btn btn-sm d-flex align-items-center gap-1
                  {% if disponibles %}btn-success{% else %}btn-outline-secondary{% endif %}"
           aria-current="{{ disponibles ? 'true' : 'false' }}">
            <i class="bi bi-check-circle" aria-hidden="true"></i>
            Disponibles
        </a>

    </div>

    {# ── Compteur ────────────────────────────────────────────────────── #}
    <p class="text-muted mb-3" style="font-size: .875rem;"
       aria-live="polite" aria-atomic="true">
        {% set total = collegues|length %}
        {% if total == 0 %}
            Aucun collègue trouvé
        {% elseif total == 1 %}
            1 collègue trouvé
        {% else %}
            {{ total }} collègues trouvés
        {% endif %}
    </p>

    {# ── Grille de cartes ────────────────────────────────────────────── #}
    {% if collegues|length == 0 %}

        <div class="text-center py-5 text-muted">
            <i class="bi bi-people fs-1 d-block mb-3" aria-hidden="true"></i>
            {% if disponibles %}
                <p class="mb-1 fw-semibold">Aucun collègue disponible en ce moment.</p>
                <p class="mb-0">Tous vos collègues sont actuellement en RDV.</p>
            {% elseif filtreMonService %}
                <p class="mb-1 fw-semibold">Aucun collègue avec des créneaux actifs dans votre service.</p>
                <p class="mb-0">
                    <a href="{{ path('app_collegues_liste') }}" class="text-decoration-none">
                        Voir tous les collègues
                    </a>
                </p>
            {% else %}
                <p class="mb-1 fw-semibold">Aucun collègue avec des créneaux actifs en ce moment.</p>
                <p class="mb-0">Vos collègues apparaîtront ici dès qu'ils auront des créneaux planifiés.</p>
            {% endif %}
        </div>

    {% else %}

        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3"
             aria-label="Liste des collègues">
            {% for dto in collegues %}
                <div class="col">
                    {{ include('components/carte_collegue.html.twig', { dto: dto }) }}
                </div>
            {% endfor %}
        </div>

    {% endif %}

</div>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .cs-badge-libre  { color: #155724; }
        .cs-badge-en-rdv { color: #7c4700; }
    </style>
{% endblock %}
