# SECRETS Symfony de la PRODUCTION (US-9.2) — GABARIT versionné.
# Copier en `.env.prod.local` (gitignoré) et renseigner les vraies valeurs.
# Injecté dans le conteneur app/worker-prod via `env_file:`.

# Clé applicative (générer : `php bin/console secrets:generate-keys` ou 32+ octets aléatoires).
APP_SECRET=CHANGER_par_une_cle_aleatoire_32_octets

# Connexion à la base prod (user dédié créé par docker/mysql/init-prod.sh).
# Le mot de passe doit correspondre à MYSQL_PROD_PASSWORD (.env.deploy.local).
DATABASE_URL="mysql://creaslot_prod:CHANGER_prod@db:3306/creaslot_prod?serverVersion=8.0.0&charset=utf8mb4"

# Envoi d'emails (ex. Brevo SMTP). `null://null` pour ne rien envoyer.
MAILER_DSN=null://null
