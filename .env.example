# Copier ce fichier en .env.local et remplir les valeurs réelles.
# Ce fichier est commité — ne jamais mettre de secrets dedans.
#
# Usage :
#   cp .env.example .env.local
#   # Editer .env.local avec les vraies valeurs

# Environnement Symfony : dev | test | preprod | prod
APP_ENV=dev

# Clé secrète Symfony — générer avec : php bin/console secret:generate-keys
# ou : openssl rand -hex 16
APP_SECRET=<32-caracteres-aleatoires>

# Étiquette affichée dans le bandeau visuel : dev | preprod | prod
APP_ENVIRONMENT_LABEL=dev

# URL de connexion MySQL
# Format : mysql://USER:PASSWORD@HOST:PORT/DATABASE?serverVersion=8.0&charset=utf8mb4
DATABASE_URL="mysql://creaslot:votrepassword@db:3306/creaslot?serverVersion=8.0&charset=utf8mb4"

# Identifiants MySQL (doivent correspondre à DATABASE_URL)
MYSQL_DATABASE=creaslot
MYSQL_USER=creaslot
MYSQL_PASSWORD=<votre-mot-de-passe>
MYSQL_ROOT_PASSWORD=<mot-de-passe-root>

# DSN Brevo (Sendinblue) pour les emails transactionnels
# Format : brevo+smtp://VOTRE_API_KEY@default
# null://null désactive l'envoi en développement local
MAILER_DSN=null://null

# Compte administrateur initial
APP_ADMIN_EMAIL=admin@creaslot.re
APP_ADMIN_INITIAL_PASSWORD=<mot-de-passe-temporaire>

# Emails transactionnels
APP_NOTIFICATION_FROM=noreply@creaslot.re
APP_NOTIFICATION_REPLY_TO=contact@creaslot.re
