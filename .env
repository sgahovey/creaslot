# Variables d'environnement par défaut — COMMITÉ, sans secrets réels.
# Pour les valeurs sensibles en local, créer un fichier .env.local (gitignoré).
# Sur Railway, configurer les variables dans le dashboard (jamais committées).

###> symfony/framework-bundle ###
APP_ENV=dev
# Placeholder 32 caractères — REMPLACER avant le premier déploiement
APP_SECRET=changeme_please_use_32chars_xxxxx
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
# URL de base pour la génération d'URLs en contexte CLI (commandes Symfony)
DEFAULT_URI=http://localhost:8000
###< symfony/routing ###

# Étiquette d'environnement — affiche un bandeau visuel en preprod
# Valeurs : dev | preprod | prod
APP_ENVIRONMENT_LABEL=preprod

# Mode pré-production — active le bandeau, le préfixe [PRÉPROD] dans <title> et la class CSS cs-env-preprod
# true en dev/preprod, false en production Railway
APP_PREPROD=true

###> doctrine/doctrine-bundle ###
# Connexion MySQL vers le service "db" du docker-compose
DATABASE_URL="mysql://creaslot:creaslot@db:3306/creaslot?serverVersion=8.0&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

# Identifiants MySQL (doivent correspondre à docker-compose.yml)
MYSQL_DATABASE=creaslot
MYSQL_USER=creaslot
MYSQL_PASSWORD=creaslot
MYSQL_ROOT_PASSWORD=rootpassword

###> symfony/mailer ###
# Placeholder — Remplacer par le DSN Brevo en .env.local ou sur Railway
MAILER_DSN=null://null
###< symfony/mailer ###

# Email de l'administrateur initial (utilisé par app:create-admin en US-1.6)
APP_ADMIN_EMAIL=admin@creaslot.re
APP_ADMIN_INITIAL_PASSWORD=change-me-on-first-login

# Expéditeur des emails transactionnels (Brevo)
APP_NOTIFICATION_FROM=noreply@creaslot.re
APP_NOTIFICATION_REPLY_TO=contact@creaslot.re

###> symfony/messenger ###
# Choose one of the transports below
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###
