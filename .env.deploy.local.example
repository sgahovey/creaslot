# Variables d'INFRA pour `docker compose -f compose.prod.yml` (US-9.2) — GABARIT versionné.
# Copier en `.env.deploy.local` (gitignoré) et renseigner, puis TOUJOURS lancer avec :
#   docker compose -f compose.prod.yml --env-file .env.deploy.local <cmd>
# Ce fichier sépare l'interpolation ${...} de compose du dotenv Symfony (qui porte
# APP_ENV=dev) afin d'éviter toute pollution croisée.

# --- Caddy : hôtes des 2 sites ---
# Local : *.localhost (ajouter au besoin dans /etc/hosts). VPS : *.<IP>.sslip.io
PREPROD_HOST=preprod.localhost
PROD_HOST=prod.localhost

# --- Caddy : TLS ---
# Local : "internal" (CA locale). VPS : une adresse email -> ACME Let's Encrypt.
CADDY_TLS=internal

# --- Caddy : ports hôte (isolés du dev qui occupe 8000/8080) ---
CADDY_HTTPS_PORT=8443
CADDY_HTTP_PORT=8081

# --- Caddy : basic-auth de la pré-production ---
# Hash bcrypt généré par : docker run --rm caddy:2-alpine caddy hash-password --plaintext '<motdepasse>'
PREPROD_BASICAUTH_USER=admin
PREPROD_BASICAUTH_HASH=REMPLACER_PAR_UN_HASH_BCRYPT

# --- MySQL (service db + docker/mysql/init-prod.sh) ---
MYSQL_ROOT_PASSWORD=CHANGER_root
MYSQL_PREPROD_PASSWORD=CHANGER_preprod
MYSQL_PROD_PASSWORD=CHANGER_prod
