# .env.local.example — Modèle pour .env.local (jamais commité, gitignoré).
#
# Ce fichier liste UNIQUEMENT les variables qui doivent recevoir une vraie
# valeur en local (secrets, identifiants, options de DEV). Les variables non
# sensibles vivent dans .env (commité) ou .env.dev (commité). Pour le modèle
# générique de toutes les variables du projet, voir .env.example.
#
# Usage :
#   cp .env.local.example .env.local
#   # Editer .env.local avec les valeurs réelles
#   docker compose down && docker compose up -d   # recharger les env vars

# ─ Mailer Brevo ───────────────────────────────────────────────────────────
# Récupérer les identifiants SMTP dans Brevo : Paramètres → Clés API SMTP & API.
# Login = adresse "VOTRE_LOGIN@smtp-brevo.com" (le @ est encodé en %40 dans le DSN).
# Password = clé SMTP commençant par "xsmtpsib-...".
# Le host "default" est résolu en interne par le bridge brevo+smtp (= smtp-relay.brevo.com).
MAILER_DSN=brevo+smtp://VOTRE_LOGIN%40smtp-brevo.com:VOTRE_CLE_SMTP@default

# ─ Redirection des emails en DEV (optionnel) ──────────────────────────────
# Si définie, le NotificationService redirige TOUS les emails vers cette
# adresse au lieu du destinataire prévu. Le sujet est préfixé
# "[DEV→destinataire-original@exemple.fr]" pour conserver la traçabilité.
# Pratique pour tester avec les fixtures sans envoyer à de vrais utilisateurs.
# Laisser commenté pour désactiver la redirection.
# APP_MAILER_REDIRECT_TO=creaslotdemo@gmail.com
